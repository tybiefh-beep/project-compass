  Z['docs.section7.title']='Skill 字段说明'; E['docs.section7.title']='Skill Field Reference';
  Z['docs.section7.li1']='<code>&lt;name&gt;</code> — 唯一标识，字母+连字符'; E['docs.section7.li1']='<code>&lt;name&gt;</code> — Unique ID, letters + hyphens';
  Z['docs.section7.li2']='<code>&lt;description&gt;</code> — 一句话描述，AI 用来理解用途'; E['docs.section7.li2']='<code>&lt;description&gt;</code> — One-line description for AI context';
  Z['docs.section7.li3']='<code>&lt;trigger&gt;</code> — 触发关键词或正则，支持 | 分隔'; E['docs.section7.li3']='<code>&lt;trigger&gt;</code> — Trigger keywords or regex, | delimited';
  Z['docs.section7.li4']='<code>&lt;anti-trigger&gt;</code> — 排除场景，防止误触发'; E['docs.section7.li4']='<code>&lt;anti-trigger&gt;</code> — Exclusion patterns to prevent false triggers';
  Z['docs.section7.li5']='<code>&lt;steps&gt;</code> — 执行步骤，每步一行，顺序执行'; E['docs.section7.li5']='<code>&lt;steps&gt;</code> — Execution steps, one per line, sequential';

  Z['docs.section8.title']='Skill 触发机制'; E['docs.section8.title']='Skill Trigger Mechanism';
  Z['docs.section8.p1']='Claude Code 在每条用户消息前检查所有 skill：'; E['docs.section8.p1']='Claude Code checks all skills before each user message:';
  Z['docs.section8.li1']='用户输入匹配 trigger → 加载该 skill 的 steps'; E['docs.section8.li1']='Input matches trigger → load that skill\'s steps';
  Z['docs.section8.li2']='同时匹配多个 skill → 全部加载，按文件名排序'; E['docs.section8.li2']='Multiple skills match → all loaded, sorted by filename';
  Z['docs.section8.li3']='匹配 anti-trigger → 排除该 skill，即使 trigger 命中'; E['docs.section8.li3']='Matches anti-trigger → exclude that skill even if trigger hits';
  Z['docs.section8.li4']='trigger 太宽 → 干扰正常对话；太窄 → 永不触发'; E['docs.section8.li4']='Trigger too broad → disrupts conversation; too narrow → never fires';
  Z['docs.section8.p2']='关键：trigger 应足够具体，避免与系统内置行为重叠。'; E['docs.section8.p2']='Key: triggers should be specific enough to avoid overlapping with built-in behavior.';

