  Z['docs.section3.title']='@ 导入语法'; E['docs.section3.title']='@ Import Syntax';
  Z['docs.section3.p1']='用 <code>@文件路径</code> 导入其他文件内容，拼接到指令中：'; E['docs.section3.p1']='Use <code>@filepath</code> to import and splice other file contents into instructions:';
  Z['docs.section3.p2']='适合引用已有文档，避免维护两份相同内容。'; E['docs.section3.p2']='Great for referencing existing docs—avoid maintaining duplicate content.';

