  Z['msg.verifyFormatOk']='✓ {model} [STAGE:N] 格式测试通过'; E['msg.verifyFormatOk']='✓ {model} [STAGE:N] format test passed';
  Z['msg.verifyFormatFail']='⚠ {model} 格式测试：输出中未检测到 [STAGE:N] 标记。该模型可能不适合本生成器。\n实际输出前80字：{reply}'; E['msg.verifyFormatFail']='⚠ {model} format test: no [STAGE:N] markers detected. This model may not be suitable.\nFirst 80 chars of output: {reply}';
  Z['msg.verifyFormatHttpErr']='⚠ 格式测试请求失败 (HTTP {status})，跳过'; E['msg.verifyFormatHttpErr']='⚠ Format test request failed (HTTP {status}), skipped';
  Z['msg.verifyFormatErr']='⚠ 格式测试出错：{msg}'; E['msg.verifyFormatErr']='⚠ Format test error: {msg}';
  Z['msg.verifyResponseErr']='⚠ {model} 响应格式异常。\n{detail}\n请在左侧「模型版本」中确认所选模型兼容 OpenAI chat/completions 格式。'; E['msg.verifyResponseErr']='⚠ {model} response format error.\n{detail}\nPlease verify the selected model is compatible with OpenAI chat/completions format.';
  Z['msg.verifyFailed']='验证失败：{msg}'; E['msg.verifyFailed']='Verification failed: {msg}';
  Z['msg.feedbackThanks']='📊 感谢反馈！已积累 {total} 条评价{extra}'; E['msg.feedbackThanks']='📊 Thanks for the feedback! {total} rating(s) collected{extra}';
  Z['msg.feedbackLearningActive']='（学习机制已激活）'; E['msg.feedbackLearningActive']=' (learning system active)';
  Z['msg.fullAutoPatches']='全自动：{count} 条修补已自动采纳'; E['msg.fullAutoPatches']='Auto: {count} patch(es) auto-applied';
  Z['msg.checkpointBoth']='⏸ 阶段{s1}「{name1}」和阶段{s2}「{name2}」已同时完成 — 请检查后回复确认，或提出修改意见'; E['msg.checkpointBoth']='⏸ Stage {s1} "{name1}" and Stage {s2} "{name2}" completed — please review and confirm, or request changes';
  Z['msg.checkpointDone']='⏸ 阶段{s}「{name}」已完成 — 请检查后回复确认，或提出修改意见'; E['msg.checkpointDone']='⏸ Stage {s} "{name}" completed — please review and confirm, or request changes';
  Z['msg.patchAdoptedUser']='修补 {id} 已采纳（用户修改）'; E['msg.patchAdoptedUser']='Patch {id} adopted (user modified)';
  Z['msg.patchAdoptedAi']='修补 {id} 已采纳（AI 选项）'; E['msg.patchAdoptedAi']='Patch {id} adopted (AI option)';
  Z['msg.compareAdopted']='✓ 已采纳 {type} 更新'; E['msg.compareAdopted']='✓ {type} update adopted';
  Z['msg.compareKept']='✗ 已保留 {type} 旧版本'; E['msg.compareKept']='✗ {type} old version kept';
  Z['msg.noFiles']='无文件'; E['msg.noFiles']='No files';

  // AI error
  Z['error.aiRequest']='⚠️ 请求失败：{msg}\n\n检查：Key 是否正确、模型是否存在、账户是否有余额、网络是否可访问该服务。'; E['error.aiRequest']='⚠️ Request failed: {msg}\n\nCheck: Is the Key correct? Does the model exist? Does the account have credits? Is the service reachable?';
})();

function t(key, params){
  const map = I18N[S.locale] || I18N.zh;
  let val = map[key];
  if(val === undefined){
    val = (I18N.zh || {})[key];
    if(val === undefined) return '['+key+']';
  }
  if(params && typeof val === 'string'){
    return val.replace(/\{(\w+)\}/g, (_, k) =>
      params[k] !== undefined ? String(params[k]) : '{'+k+'}'
    );
  }
  return val;
}

function applyI18n(){
  document.documentElement.setAttribute('lang', S.locale==='en'?'en':'zh');
  document.querySelectorAll('[data-i18n]').forEach(el => {
    el.textContent = t(el.getAttribute('data-i18n'));
  });
  document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
    el.setAttribute('placeholder', t(el.getAttribute('data-i18n-placeholder')));
  });
  document.querySelectorAll('[data-i18n-title]').forEach(el => {
    el.setAttribute('title', t(el.getAttribute('data-i18n-title')));
  });
}

function toggleLocale(){
  const next = S.locale==='zh'?'en':'zh';
  S.locale = next;
  try{ localStorage.setItem('csg_locale', next); }catch(e){}
  // 如果是默认提示词，切换语言版本；用户自定义的保留
  if(S.systemPrompt===DEFAULT_SYSTEM_PROMPT||S.systemPrompt===DEFAULT_SYSTEM_PROMPT_EN){
    S.systemPrompt = next==='en'?DEFAULT_SYSTEM_PROMPT_EN:DEFAULT_SYSTEM_PROMPT;
    try{ localStorage.setItem('csg_system_prompt', S.systemPrompt); }catch(e){}
  }
  applyI18n();
  refreshKnowledge();
  updateTopbar();
  updateFileCards();
  updateLocalMdCard();
  updateSkillCards();
  if(S.history.length===0){
    document.getElementById('chat').innerHTML='';
    addMsg('ai', t('welcome.message'));
  }
}

// ====== INIT ======
function init(){
  // 恢复折叠状态
  const collapsed = ls('csg_providers_collapsed');
  const list=document.getElementById('providerList');
  PROVIDERS.forEach(p=>{
    const btn=document.createElement('button');
    btn.className='pb';btn.id='pb-'+p.id;
    btn.onclick=()=>selectProvider(p.id);
    list.appendChild(btn);
  });
  if(collapsed==='1'){ list.classList.add('collapsed'); document.getElementById('secToggle').classList.add('folded'); }
  refreshProviderGrid();
  initProject();
  setMode(S.mode);
  const savedFontSize=ls('fontSize')||'medium';
  setFontSize(savedFontSize);
  initPrefs();
  initGitHub();
  setupDragDrop();
  refreshKnowledge();
  // 加载日夜主题
  const savedTheme=ls('csg_theme')||'dark';
  applyTheme(savedTheme);
  applyI18n();
  // 初始化阶段进度条
  renderStageProgress();
  // 恢复 docs-panel 折叠状态
  if(ls('csg_docs_collapsed')==='1'){
    const dp=document.getElementById('docsPanel');
    const app=document.querySelector('.app');
    if(dp){dp.classList.add('collapsed');document.getElementById('docsToggle').textContent='▶';}
    if(app) app.classList.add('docs-collapsed');
  }
  addMsg('ai', t('welcome.message'));
}

function toggleTheme(){
  const cur=document.documentElement.getAttribute('data-theme')||'dark';
  const next=cur==='dark'?'light':'dark';
  applyTheme(next);
  lset('csg_theme',next);
}

function toggleDocsPanel(){
  const dp=document.getElementById('docsPanel');
  const btn=document.getElementById('docsToggle');
  const app=document.querySelector('.app');
  if(!dp||!btn||!app) return;
  dp.classList.toggle('collapsed');
  app.classList.toggle('docs-collapsed');
  const isCollapsed=dp.classList.contains('collapsed');
  btn.textContent=isCollapsed?'▶':'◀';
  lset('csg_docs_collapsed',isCollapsed?'1':'0');
}

function renderStageProgress(){
  const container=document.getElementById('stageProgress');
  if(!container) return;
  const stageNames=['',t('stage.0')||'项目描述',t('stage.1')||'工具架构',t('stage.2')||'自动化识别',t('stage.3')||'CLAUDE.md',t('stage.4')||'SKILL.md',t('stage.5')||'监督修补',t('stage.6')||'文件就绪'];
  // 阶段产出预览（鼠标悬停时显示，索引与阶段号对齐）
  const stageOutputs=[
    '',                                          // 0: 未使用
    '→ 收集项目描述、技术栈、痛点',              // 1: 项目描述
    '→ 输出工具关系图和最佳实践方案',            // 2: 工具架构
    '→ 推荐 automation 模式和干预点',            // 3: 自动化识别
    '→ 产生 CLAUDE.md（项目操作手册）',          // 4: CLAUDE.md 生成
    '→ 产生 SKILL.md（日常重复操作封装）',       // 5: SKILL.md 提取
    '→ 输出交叉审查修补建议',                    // 6: 监督修补
    '→ 文件可导出'                               // 7: 文件就绪
  ];
  let html='<div class="sp-track">';
  for(let i=1;i<=7;i++){
    const isDone=S.stage>=i;
    const isActive=S.stage===i;
    const cls=isDone?'done':isActive?'active':'';
    const icon=isDone?'✓':i;
    const line=i<7?'<div class="sp-line'+(S.stage>=i?' done':'')+'"></div>':'';
    const tip=stageNames[i]+'\n'+(stageOutputs[i]||'');
    html+=`<div class="sp-node ${cls}" onclick="goToStage(${i})" title="${esc(tip)}">${icon}</div>${line}`;
  }
  html+='</div>';
  html+=`<span class="sp-label">阶段 <strong>${S.stage}</strong>/7: ${stageNames[S.stage]||'项目描述'}</span>`;
  // checkpoint 模式显示导航按钮
  if(S.mode==='checkpoint'){
    html+=`<div class="sp-nav">
      <button class="sp-nav-btn" onclick="goToStage(${Math.max(1,S.stage-1)})" ${S.stage<=1?'disabled':''}>← 上一阶段</button>
      <button class="sp-nav-btn" onclick="goToStage(${Math.min(7,S.stage+1)})" ${S.stage>=7?'disabled':''}>下一阶段 →</button>
    </div>`;
  }
  container.innerHTML=html;
}

function goToStage(n){
  // 允许回退到任意 ≤ 当前阶段的节点（已完成的阶段可重访）
  if(n<1 || n>7) return;
  setStage(n);
}

function applyTheme(theme){
  document.documentElement.setAttribute('data-theme',theme);
  const btn=document.getElementById('themeToggle');
  if(btn) btn.textContent=theme==='dark'?'🌙':'☀️';
}

function toggleProviders(){
  const list=document.getElementById('providerList');
  const arrow=document.getElementById('secToggle');
  list.classList.toggle('collapsed');
  arrow.classList.toggle('folded');
  lset('csg_providers_collapsed',list.classList.contains('collapsed')?'1':'0');
}

function refreshProviderGrid(){
  PROVIDERS.forEach(p=>{
    const btn=document.getElementById('pb-'+p.id);
    if(!btn) return;
    const hasKey = !!S.apiKeys[p.id];
    const model = S.selectedModel[p.id] || p.defaultModel;
    // 检查验证状态
    const vkey = p.id+':'+model;
    const verified = S.verifiedModels[vkey];
    let statusHtml = '', statusCls = '';
    if(verified===true){ statusHtml=t('provider.connected'); statusCls='ok'; }
    else if(hasKey){ statusHtml=t('provider.hasKey'); statusCls='key'; }

    const isActive = S.provider && S.provider.id===p.id;
    btn.className='pb'+(isActive?' active':'');
    btn.innerHTML=`
      <div class="pdot" style="background:${p.dot}"></div>
      <span class="pb-name">${p.name}</span>
      ${statusHtml?`<span class="pb-status ${statusCls}">${statusHtml}</span>`:''}
      <span class="pb-model">${model}</span>`;
  });
}

function selectProvider(id){
  S.provider=PROVIDERS.find(p=>p.id===id);

  // restore saved key
  const saved=S.apiKeys[id]||'';
  document.getElementById('apiKeyInput').value=saved;
  document.getElementById('apiStatus').className='api-status '+(saved?'ok':'none');
  document.getElementById('apiStatus').textContent=saved?t('status.saved'):t('status.notConfigured');

  // base url for custom
  document.getElementById('baseUrlRow').style.display=(id==='custom')?'block':'none';

  // build model select
  buildModelSelect();
  document.getElementById('modelSec').style.display='block';
  updateTopbar();
  refreshProviderGrid();
  initLearningStats();
}

function buildModelSelect(){
  const p=S.provider;
  const sel=document.getElementById('modelSelect');
  sel.innerHTML='';
  p.models.forEach(m=>{
    const opt=document.createElement('option');
    opt.value=m.id;
    const tagMap={r:t('tag.recommended'),p:t('tag.preview'),l:t('tag.legacy')};
    opt.textContent=(tagMap[m.tag]||'')+m.label;
    sel.appendChild(opt);
  });
  // restore or default
  const saved=S.selectedModel[p.id]||p.defaultModel;
  sel.value=saved||p.models[0].id;
  onModelChange();
}

function onModelChange(){
  const p=S.provider; if(!p) return;
  const sel=document.getElementById('modelSelect');
  const val=sel.value;
  S.selectedModel[p.id]=val;
  const isCustom=val==='__custom__';
  document.getElementById('modelCustomRow').style.display=isCustom?'block':'none';

  const key=p.id+':'+(isCustom?'__custom__':val);
  const verified=S.verifiedModels[key];
  if(verified===true) setModelStatus('ok',t('status.verified'));
  else if(verified===false) setModelStatus('err',t('status.verifyFailed'));
  else setModelStatus('none',t('status.notVerified'));
  updateTopbar();
  refreshProviderGrid();
}

function onCustomModelInput(){
  setModelStatus('none','· 未验证');
}

function getActiveModel(){
  const p=S.provider; if(!p) return '';
  const sel=document.getElementById('modelSelect');
  if(sel.value==='__custom__'){
    return document.getElementById('modelCustomInput').value.trim();
  }
  return sel.value;
}

function setModelStatus(type,text){
  const el=document.getElementById('modelStatus');
  el.className='model-status '+type;
  el.textContent=text;
  el.setAttribute('data-i18n',''); // prevent applyI18n from overwriting dynamic status
}

function httpErrorMsg(status, body){
  const tips = {
    400: t('error.http400'),
    401: t('error.http401'),
    403: t('error.http403'),
    404: t('error.http404'),
    429: t('error.http429'),
    500: t('error.http500'),
    502: t('error.http502'),
    503: t('error.http503')
  };
  const tip = tips[status] || `HTTP ${status}`;
  const detail = body.slice(0, 200);
  return `${tip}\n详情：${detail}`;
}

async function verifyModel(){
  const p=S.provider; if(!p) return;
  const key=S.apiKeys[p.id];
  if(!key){alert(t('alert.saveApiKeyFirst'));return;}
  const model=getActiveModel();
  if(!model){alert(t('alert.enterModelId'));return;}

  setModelStatus('checking',t('status.verifying'));
  document.getElementById('verifyBtn').disabled=true;

  try{
    let body=p.verifyBody(model,key);
    let url=p.customUrl&&body._url?body._url:p.baseUrl;
    if(body._url) delete body._url;
    if(p.id==='custom'){
      const cu=document.getElementById('baseUrlInput').value.trim();
      if(cu) url=cu;
    }

    const res=await fetch(url,{method:'POST',headers:p.headers(key),body:JSON.stringify(body)});
    if(!res.ok){
      const err=await res.text();
      throw new Error(httpErrorMsg(res.status, err));
    }
    const data=await res.json();
    const ok=p.verifyCheck(data);
    const vkey=p.id+':'+model;
    S.verifiedModels[vkey]=ok;
    localStorage.setItem('csg_verified',JSON.stringify(S.verifiedModels));

    if(ok){
      setModelStatus('ok',`· 验证通过 ✓ — ${model}`);
      addSysMsg(t('msg.verifySuccess',{model}));
      // 第二层验证：测试 [STAGE:N] 标记输出格式
      try{
        const stageTestSys = '你是一个项目规范生成助手。回复必须以 [STAGE:1] 开头，然后简短确认收到指令。';
        const stageTestMsg = [{role:'user',content:'确认你的当前阶段。'}];
        let sBody = p.buildBody(stageTestMsg, stageTestSys, model, key);
        let sUrl = p.customUrl && sBody._url ? sBody._url : p.baseUrl;
        if(sBody._url) delete sBody._url;
        const sRes = await fetch(sUrl, {method:'POST', headers: p.headers(key), body: JSON.stringify(sBody)});
        if(sRes.ok){
          const sData = await sRes.json();
          const sReply = p.parseReply(sData);
          const hasStage = /\[STAGE:\d\]/.test(sReply);
          if(hasStage){
            addSysMsg(t('msg.verifyFormatOk',{model}));
          } else {
            addSysMsg(t('msg.verifyFormatFail',{model, reply:sReply.slice(0,80)}));
          }
        } else {
          addSysMsg(t('msg.verifyFormatHttpErr',{status:sRes.status}));
        }
      }catch(e){
        addSysMsg(t('msg.verifyFormatErr',{msg:e.message.slice(0,100)}));
      }
    } else {
      // 逐字段诊断，定位具体缺失什么
      const c0 = data.choices?.[0];
      const detail = [];
      detail.push(`choices 存在: ${Array.isArray(data.choices)}`);
      if (c0) {
        detail.push(`choices[0].message 存在: ${!!c0.message}`);
        if (c0.message) {
          detail.push(`message.content 类型: ${typeof c0.message.content}`);
          detail.push(`message.content 值: ${JSON.stringify(c0.message.content).slice(0, 80)}`);
        }
        detail.push(`choices[0] 完整结构: ${JSON.stringify(c0).slice(0, 200)}`);
      } else {
        // 可能用了其他字段名（如 text、delta 等）
        detail.push(`choices[0] 完整结构: ${JSON.stringify(c0).slice(0, 200)}`);
        detail.push(`data 顶层键: ${Object.keys(data).join(', ')}`);
      }
      setModelStatus('err',`· 响应格式异常，详情见聊天区`);
      addSysMsg(t('msg.verifyResponseErr',{model, detail:detail.join('\n')}));
    }
  }catch(e){
    const vkey=p.id+':'+model;
    S.verifiedModels[vkey]=false;
    localStorage.setItem('csg_verified',JSON.stringify(S.verifiedModels));
    setModelStatus('err','· 验证失败: '+e.message.slice(0,200));
    addSysMsg(t('msg.verifyFailed',{msg:e.message.slice(0,500)}));
  }
  document.getElementById('verifyBtn').disabled=false;
  updateTopbar();
  refreshProviderGrid();
}

function saveApiKey(){
  if(!S.provider){alert(t('alert.selectProviderFirst'));return;}
  const key=document.getElementById('apiKeyInput').value.trim();
  if(!key){alert(t('alert.enterApiKey'));return;}
  S.apiKeys[S.provider.id]=key;
  lset('csg_keys',JSON.stringify(S.apiKeys));
  document.getElementById('apiStatus').className='api-status ok';
  document.getElementById('apiStatus').textContent='· 已保存';
  if(S.provider.id==='custom'){
    const cu=document.getElementById('baseUrlInput').value.trim();
    if(cu) S.provider.baseUrl=cu;
  }
  refreshProviderGrid();
}

function setMode(m){
  S.mode=m;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+m).classList.add('active');
  updateTopbar();
  autoSaveProject();
}

// ====== 个人偏好 (CLAUDE.local.md) ======
function togglePrefs(){
  const panel=document.getElementById('prefsPanel');
  const arrow=document.getElementById('prefsToggle');
  const collapsed=panel.style.display==='none';
  panel.style.display=collapsed?'':'none';
  arrow.classList.toggle('folded',!collapsed);
  lset('csg_prefs_collapsed', collapsed?'0':'1');
}
function onPrefsChange(){
  S.localMd=document.getElementById('prefsInput').value;
  try{ localStorage.setItem('csg_local_md', S.localMd); }catch(e){}
  document.getElementById('genLocalMdBtn').disabled=!S.localMd.trim();
  document.getElementById('prefsStatus').textContent=S.localMd.trim()?t('prefs.savedCount',{count:S.localMd.split('\n').filter(l=>l.trim()).length}):'';
  updateLocalMdCard();
}
function updateLocalMdCard(){
  const lines=S.localMd.split('\n').filter(l=>l.trim()).length;
  document.getElementById('fcMetaLocal').textContent=lines?t('fileCard.prefCount',{count:lines}):t('fileCard.localMeta');
  document.getElementById('fcViewLocal').disabled=!lines;
}
function savePrefs(){
  S.localMd=document.getElementById('prefsInput').value;
  try{ localStorage.setItem('csg_local_md', S.localMd); }catch(e){}
  document.getElementById('prefsStatus').textContent=S.localMd.trim()?t('prefs.savedDone',{count:S.localMd.split('\n').filter(l=>l.trim()).length}):t('prefs.notSet');
  addSysMsg(t('msg.prefsSaved'));
}
function generateLocalMd(){
  if(!S.localMd.trim()) return;
  let content=t('localMd.template.header')+'\n';
  S.localMd.split('\n').filter(l=>l.trim()).forEach(line=>{
    content+=`- ${line.trim()}\n`;
  });
  content+='\n'+t('localMd.template.footer')+'\n';
  // 下载
  const a=document.createElement('a');
  a.href='data:text/markdown;charset=utf-8,'+encodeURIComponent(content);
  a.download='CLAUDE.local.md';a.click();
  addSysMsg(t('msg.localMdDownloaded'));
}
function initPrefs(){
  const input=document.getElementById('prefsInput');
  if(input) input.value=S.localMd;
  document.getElementById('genLocalMdBtn').disabled=!S.localMd.trim();
  const collapsed=ls('csg_prefs_collapsed');
  if(collapsed==='1'){
    document.getElementById('prefsPanel').style.display='none';
    document.getElementById('prefsToggle').classList.add('folded');
  }
  updateLocalMdCard();
}

function setFontSize(size){
  const map={small:{chat:'14px',input:'15px'},medium:{chat:'16px',input:'17px'},large:{chat:'18px',input:'19px'}};
  const v=map[size]||map.medium;
  document.documentElement.style.setProperty('--chat-font',v.chat);
  document.documentElement.style.setProperty('--input-font',v.input);
  document.querySelectorAll('#fs-small,#fs-medium,#fs-large').forEach(b=>b.classList.remove('active'));
  document.getElementById('fs-'+size).classList.add('active');
  lset('fontSize',size);
}

function updateTopbar(){
  const p=S.provider;
  const model=getActiveModel();
  if(p&&model){
    document.getElementById('topbarInfo').textContent=t('topbar.modeInfo',{provider:p.name, mode:t('mode.'+S.mode)||S.mode});
    const tm=document.getElementById('topbarModel');
    tm.style.display='';
    tm.textContent=model;
  } else {
    document.getElementById('topbarInfo').textContent=t('topbar.defaultInfo');
  }
}

function setStage(n){
  S.stage=n;
  // 更新旧版侧边阶段指示器（兼容）
  for(let i=0;i<=6;i++){
    const el=document.getElementById('si-'+i);
    if(el) el.className='si'+(i<n?' done':i===n?' active':'');
  }
  // 更新顶部进度条
  renderStageProgress();
}

// ====== CHAT ======
function addMsg(role,html,idx){
  const chat=document.getElementById('chat');
  const row=document.createElement('div');
  row.className='msg-row'+(role==='human'?' user':'');
  if(idx!==undefined) row.setAttribute('data-hidx',idx);
  const av=document.createElement('div');
  av.className='av '+(role==='ai'?'ai':'hu');
  av.textContent=role==='ai'?'AI':t('chat.me');
  const bub=document.createElement('div');
  bub.className='bubble';
  let contentHtml=md(html);
  if(role==='human'&&idx!==undefined){
    contentHtml+=`<button class="msg-retract" onclick="retractMessage(${idx})" title="${t('chat.retractTitle')}">${t('chat.retract')}</button>`;
  }
  bub.innerHTML=contentHtml;
  row.appendChild(av);row.appendChild(bub);
  chat.appendChild(row);
  chat.scrollTop=chat.scrollHeight;
  return bub;
}

function retractMessage(idx){
  if(S.loading) return;
  const chat=document.getElementById('chat');
  // 找到目标消息行，删除它及之后所有元素
  const target=chat.querySelector(`[data-hidx="${idx}"]`);
  if(!target) return;
  let el=target;
  while(el){
    const next=el.nextSibling;
    el.remove();
    el=next;
  }
  // 截断历史
  S.history=S.history.slice(0,idx);
  // 重新评估阶段和文件状态
  reevaluateState();
  autoSaveProject();
  addSysMsg(t('msg.retracted'));
}

function reevaluateState(){
  S.claudeMd='';S.skillMd='';S.stage=0;
  S._pendingClaudeMd=null;S._pendingSkillMd=null;
  S._prevClaudeMd='';S._prevSkillMd='';
  S._justGenerated=null;
  for(const msg of S.history){
    if(msg.role==='assistant'){
      const sm=msg.content.match(/\[STAGE:(\d)\]/);
      if(sm) S.stage=Math.max(S.stage,parseInt(sm[1]));
      const cm=msg.content.match(/```(?:markdown)?\s*\n(#\s*Project[\s\S]*)\n```(?=\s*(?:\n|\[STAGE:\d\]|[一-鿿]|\{|$))/);
      if(cm){S._prevClaudeMd=S.claudeMd;S.claudeMd=cm[1].trim();}
      // 提取所有 skill 代码块
      const skillRe=/```(?:xml)?\s*\n(<skill[\s\S]*?)\n```(?=\s*(?:\n|\[STAGE:\d\]|[一-鿿]|\{|$))/gi;
      let smMatch;
      while((smMatch=skillRe.exec(msg.content))!==null){
        S._prevSkillMd=S.skillMd;
        S.skillMd=mergeSkill(S.skillMd,smMatch[1].trim());
      }
    }
  }
  setStage(S.stage);
  updateFileCards();
}

// ====== FILE PERSISTENCE ======
function saveFiles(){
  try{
    if(S.claudeMd) lset('csg_claude_md',S.claudeMd);
    else lremove('csg_claude_md');
    if(S.skillMd) lset('csg_skill_md',S.skillMd);
    else lremove('csg_skill_md');
    updateFileCards();
  }catch(e){ /* localStorage 可能满了 */ }
}

function loadFiles(){
  try{
    S.claudeMd=ls('csg_claude_md');
    S.skillMd=ls('csg_skill_md');
  }catch(e){}
}

function updateFileCards(){
  function updateCard(type){
    const content=type==='claude'?S.claudeMd:S.skillMd;
    const has=!!content;
    const lines=has?content.split('\n').length:0;
    const card=document.getElementById('fileCard'+(type==='claude'?'Claude':'Skill'));
    const meta=document.getElementById('fcMeta'+(type==='claude'?'Claude':'Skill'));
    const view=document.getElementById('fcView'+(type==='claude'?'Claude':'Skill'));
    const copy=document.getElementById('fcCopy'+(type==='claude'?'Claude':'Skill'));
    const dl=document.getElementById('fcDl'+(type==='claude'?'Claude':'Skill'));
    if(card) card.className='file-card'+(has?' has-file':'');
    if(meta){
      if(!has){ meta.textContent=t('fileCard.notGenerated'); meta.className='fc-meta'; }
      else if(type==='claude'){ meta.textContent=t('fileCard.lineCount',{count:lines}); meta.className='fc-meta has-file'; }
      else {
        const names=[]; const re=/<skill\s[^>]*?name\s*=\s*"([^"]*)"/gi; let m;
        while((m=re.exec(content))!==null) names.push(m[1]);
        if(names.length) meta.textContent=t('fileCard.skillCount',{count:names.length, names:names.join(', '), lines:lines});
        else meta.textContent=t('fileCard.lineCount',{count:lines});
        meta.className='fc-meta has-file';
      }
    }
    if(view) view.disabled=!has;
    if(copy) copy.disabled=!has;
    if(dl) dl.disabled=!has;
  }
  updateCard('claude');
  updateCard('skill');
  document.getElementById('outExport').disabled=!(S.claudeMd||S.skillMd);
  updateSkillCards();
  updateGitHubStatus();
}

// 解析并渲染各 Skill 独立卡片
function updateSkillCards(){
  const container = document.getElementById('skillCards');
  if(!container) return;
  if(!S.skillMd){ container.innerHTML=''; return; }
  const skills = [];
  const re = /<skill>[\s\S]*?<\/skill>/gi;
  let m;
  while((m = re.exec(S.skillMd)) !== null){
    const xml = m[0];
    const name = (xml.match(/<name>([^<]*)<\/name>/i)||[])[1]||'未知';
    const desc = (xml.match(/<description>([^<]*)<\/description>/i)||[])[1]||'';
    skills.push({name, desc, xml});
  }
  if(skills.length === 0){ container.innerHTML=''; return; }
  container._skills = skills;
  container.innerHTML = skills.map((sk, i) => `
    <div class="file-card has-file" style="margin-top:4px;border-left:2px solid var(--accent);padding:6px 8px">
      <div class="fc-top"><span class="fc-icon">⚡</span><span class="fc-name" style="font-size:10px" title="${esc(sk.desc)}">${esc(sk.name)}</span></div>
      <div class="fc-acts" style="gap:2px">
        <button class="fc-btn" style="font-size:9px;padding:2px 6px" onclick="viewSkillXml('skill_${i}')">${t('fileCard.view')}</button>
        <button class="fc-btn" style="font-size:9px;padding:2px 6px" onclick="dlSkillXml('skill_${i}')">${t('fileCard.download')}</button>
      </div>
    </div>
  `).join('');
}

function viewSkillXml(key){
  const container = document.getElementById('skillCards');
  if(!container||!container._skills) return;
  const idx = parseInt(key.split('_')[1]);
  const sk = container._skills[idx];
  if(!sk) return;
  const modal = document.createElement('div');
  modal.className = 'mo';
  modal.innerHTML = `<div class="mb" style="max-width:700px">
    <div class="mh">
      <div class="mt">⚡ ${esc(sk.name)}</div>
      <button class="mc-btn" onclick="this.closest('.mo').remove()">×</button>
    </div>
    <div class="mc" style="font-size:11px;max-height:60vh;overflow-y:auto">${esc(sk.xml)}</div>
    <div class="mf">
      <button class="m-btn" onclick="navigator.clipboard.writeText(this.closest('.mb').querySelector('.mc').textContent);this.textContent=t('msg.copiedShort')" style="font-size:10px">${t('fileCard.copy')}</button>
      <button class="m-btn pri" onclick="dlSkillXml('${key}');this.closest('.mo').remove()" style="font-size:10px">${t('fileCard.download')}</button>
    </div></div>`;
  document.body.appendChild(modal);
}

function dlSkillXml(key){
  const container = document.getElementById('skillCards');
  if(!container||!container._skills) return;
  const idx = parseInt(key.split('_')[1]);
  const sk = container._skills[idx];
  if(!sk) return;
  const fn = sk.name.replace(/[^a-zA-Z0-9一-鿿_-]/g, '-') + '.skill.md';
  if(S._dirHandle){
    writeFileToDir(fn, sk.xml).then(ok => {
      if(ok) addSysMsg(t('msg.fileWritten',{path:getProjectName()+'/'+fn}));
      else fallbackDownload(fn, sk.xml);
    });
  } else {
    const a = document.createElement('a');
    a.href = 'data:text/xml;charset=utf-8,' + encodeURIComponent(sk.xml);
    a.download = fn; a.click();
  }
}

// ====== PROJECT MANAGEMENT ======
const PROJ_KEY='csg_projects', ACTIVE_PROJ_KEY='csg_active_project';
function getProjects(){try{return JSON.parse(localStorage.getItem(PROJ_KEY)||'[]');}catch(e){return[];}}
function saveProjects(arr){try{localStorage.setItem(PROJ_KEY,JSON.stringify(arr));}catch(e){}}
function getActiveProjId(){return ls(ACTIVE_PROJ_KEY);}
function setActiveProjId(id){lset(ACTIVE_PROJ_KEY,id);}

function autoSaveProject(){
  const activeId=getActiveProjId();
  if(!activeId) return;
  const projects=getProjects();
  const idx=projects.findIndex(p=>p.id===activeId);
  const proj={
    id:activeId,
    name:idx>=0?projects[idx].name:'默认项目',
    history:S.history.slice(),claudeMd:S.claudeMd,skillMd:S.skillMd,
    stage:S.stage,mode:S.mode,
    providerId:S.provider?S.provider.id:null,
    updatedAt:Date.now()
  };
  if(idx>=0) projects[idx]=proj; else projects.push(proj);
  saveProjects(projects);
  document.getElementById('projName').textContent=proj.name;
}

function loadProject(id){
  autoSaveProject();
  const projects=getProjects();
  const proj=projects.find(p=>p.id===id);
  if(!proj) return;
  // 恢复状态
  S.history=proj.history||[];S.claudeMd=proj.claudeMd||'';S.skillMd=proj.skillMd||'';
  S.stage=proj.stage||0;S.mode=proj.mode||'full_auto';
  S._prevClaudeMd='';S._prevSkillMd='';S._pendingClaudeMd=null;S._pendingSkillMd=null;
  if(proj.providerId){
    const p=PROVIDERS.find(p=>p.id===proj.providerId);
    if(p) selectProvider(p.id);
  }
  setActiveProjId(id);
  document.getElementById('projName').textContent=proj.name;
  setMode(S.mode);setStage(S.stage);
  updateFileCards();
  // 重建聊天
  const chat=document.getElementById('chat');chat.innerHTML='';
  S.history.forEach((msg,i)=>{
    if(msg.role==='user'){addMsg('human',msg.content,i);}
    else{
      let display=msg.content.replace(/\[STAGE:\d\]/g,'')
        .replace(/```(?:markdown|xml|bash)?[\s\S]*?```/g,cb=>{
          const inner=cb.replace(/```(?:markdown|xml|bash)?/,'').replace(/```$/,'').trim();
          if(inner.startsWith('#\x20Project')) return '[📄 CLAUDE.md 已生成]';
          if(inner.startsWith('<skill')) return '[🔧 SKILL.md 已生成]';
          return `<pre>${esc(inner)}</pre>`;
        }).replace(/^\{[^{}\n]*"patch_id"[^{}\n]*\}$/gm,'').trim();
      addMsg('ai',display||'（文件已生成）',i);
    }
  });
  const projFiles = S.claudeMd&&S.skillMd?'CLAUDE.md + SKILL.md':(S.claudeMd?'CLAUDE.md':(S.skillMd?'SKILL.md':t('msg.noFiles')));
  addSysMsg(t('msg.projectSwitched',{name:proj.name, msgs:S.history.length, files:projFiles}));
}

function newProject(){
  const name=prompt(t('prompt.newProjectName'));
  if(!name||!name.trim()) return;
  autoSaveProject();
  const id='proj_'+Date.now();
  const projects=getProjects();
  projects.push({id,name:name.trim(),history:[],claudeMd:'',skillMd:'',stage:0,mode:'checkpoint',providerId:null,updatedAt:Date.now()});
  saveProjects(projects);
  resetAll();setActiveProjId(id);
  document.getElementById('projName').textContent=name.trim();
  addSysMsg(t('msg.projectCreated',{name:name.trim()}));
}

function showProjectList(){
  const projects=getProjects();
  const activeId=getActiveProjId();
  if(projects.length===0){alert(t('alert.noOtherProjects'));return;}
  let html='';
  projects.sort((a,b)=>b.updatedAt-a.updatedAt).forEach(p=>{
    const isActive=p.id===activeId;
    const d=new Date(p.updatedAt);
    const ds=`${d.getMonth()+1}/${d.getDate()} ${d.getHours()}:${String(d.getMinutes()).padStart(2,'0')}`;
    const hasFiles=(p.claudeMd?'C':'')+(p.skillMd?' S':'');
    html+=`<div style="display:flex;align-items:center;gap:7px;padding:8px 10px;border-radius:7px;margin-bottom:3px;${isActive?'background:rgba(124,106,247,0.1);border:1px solid rgba(124,106,247,0.25)':'border:1px solid transparent'}">
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;color:var(--text);${isActive?'font-weight:600':''}">${esc(p.name)}${isActive?' <span style="font-size:9px;color:var(--accent)">当前</span>':''}</div>
        <div style="font-size:9px;color:var(--text3);margin-top:1px">${ds} · ${p.history.length}条消息${hasFiles?' · '+hasFiles:''}</div>
      </div>
      ${!isActive?`<button onclick="(()=>{const mo=document.querySelector('.mo');mo.remove();setTimeout(()=>loadProject('${p.id}'),50);})()" style="padding:3px 8px;border-radius:5px;border:1px solid var(--border2);background:var(--bg3);cursor:pointer;font-size:10px;font-family:var(--sans);color:var(--text2)">${t('project.switch')}</button>`:''}
      <button onclick="if(confirm(t('confirm.deleteProject',{name:esc(p.name)}))){deleteProject('${p.id}');document.querySelector('.mo').remove();}" style="padding:3px 6px;border-radius:5px;border:1px solid transparent;background:transparent;cursor:pointer;font-size:10px;font-family:var(--sans);color:var(--text3)" title="${t('project.deleteTitle')}">🗑</button>
    </div>`;
  });
  const overlay=document.createElement('div');overlay.className='mo';
  overlay.onclick=e=>{if(e.target===overlay)overlay.remove();};
  overlay.innerHTML=`<div class="mb" style="width:420px">
    <div class="mh"><div class="mt">项目管理</div><button class="mc-btn" onclick="this.closest('.mo').remove()">×</button></div>
    <div class="mc" style="max-height:360px">${html||'<div style="color:var(--text3);text-align:center;padding:20px">暂无项目</div>'}</div>
    <div class="mf"><button class="m-btn pri" onclick="newProject();document.querySelector('.mo').remove();">${t('project.newBtn')}</button><button class="m-btn" onclick="this.closest('.mo').remove()">${t('project.close')}</button></div>
  </div>`;
  document.body.appendChild(overlay);
}

function deleteProject(id){
  let projects=getProjects();
  projects=projects.filter(p=>p.id!==id);
  saveProjects(projects);
  if(getActiveProjId()===id){
    // 如果删除的是当前项目，切换到最近的项目
    if(projects.length>0){
      loadProject(projects[projects.length-1].id);
    } else {
      // 没有项目了，创建默认项目
      const defId='proj_'+Date.now();
      projects=[{id:defId,name:'默认项目',history:[],claudeMd:'',skillMd:'',stage:0,mode:'checkpoint',providerId:null,updatedAt:Date.now()}];
      saveProjects(projects);
      resetAll();setActiveProjId(defId);
      document.getElementById('projName').textContent='默认项目';
    }
  }
}

function initProject(){
  // 迁移旧数据：如果项目列表为空但旧格式文件存在，迁移到默认项目
  let projects=getProjects();
  const oldClaude=ls('csg_claude_md');
  const oldSkill=ls('csg_skill_md');
  if(projects.length===0&&(oldClaude||oldSkill)){
    const id='proj_'+Date.now();
    projects.push({id,name:'默认项目',history:[],claudeMd:oldClaude||'',skillMd:oldSkill||'',stage:0,mode:'checkpoint',providerId:null,updatedAt:Date.now()});
    saveProjects(projects);
    setActiveProjId(id);
    lremove('csg_claude_md');lremove('csg_skill_md');
    projects=getProjects(); // 刷新
  }
  let activeId=getActiveProjId();
  // 如果没有活跃项目或项目不存在，创建默认项目
  if(!activeId||!projects.find(p=>p.id===activeId)){
    if(projects.length>0){
      activeId=projects[projects.length-1].id;
    } else {
      activeId='proj_'+Date.now();
      projects.push({id:activeId,name:'默认项目',history:[],claudeMd:'',skillMd:'',stage:0,mode:'checkpoint',providerId:null,updatedAt:Date.now()});
      saveProjects(projects);
    }
    setActiveProjId(activeId);
  }
  const proj=projects.find(p=>p.id===activeId);
  if(proj){
    document.getElementById('projName').textContent=proj.name;
    // 恢复上次项目的文件和模式（但不重建聊天，因为欢迎消息更友好）
    S.claudeMd=proj.claudeMd||'';S.skillMd=proj.skillMd||'';S.mode=proj.mode||'checkpoint';S.stage=proj.stage||0;
    S.history=proj.history||[];
    setMode(S.mode);setStage(S.stage);
    if(proj.providerId){
      const p=PROVIDERS.find(p=>p.id===proj.providerId);
      if(p){
        S.provider=p;
        const saved=S.apiKeys[p.id]||'';
        document.getElementById('apiKeyInput').value=saved;
        document.getElementById('apiStatus').className='api-status '+(saved?'ok':'none');
        document.getElementById('apiStatus').textContent=saved?t('status.saved'):t('status.notConfigured');
        document.getElementById('baseUrlRow').style.display=(p.id==='custom')?'block':'none';
        buildModelSelect();
        document.getElementById('modelSec').style.display='block';
        updateTopbar();refreshProviderGrid();
      }
    }
    updateFileCards();
  }
}

function showRecalibratePrompt(){
  const modal=document.createElement('div');
  modal.className='mo';
  modal.innerHTML=`<div class="mb" style="max-width:480px">
    <div class="mh"><div class="mt">🧭 方向校准</div><button class="mc-btn" onclick="this.closest('.mo').remove()">×</button></div>
    <div class="mc" style="font-size:13px;line-height:1.7;color:var(--text2)">
      CLAUDE.md 已生成。你现在可以：
      <br><br>
      <b>① 确认并继续</b> — 进入阶段5 提取 skill
      <br>
      <b>② 回到前序阶段调整</b> — 如果用户画像、项目理解或自动化策略需要修正
    </div>
    <div class="mf">
      <button class="m-btn pri" onclick="this.closest('.mo').remove()">继续 →</button>
      <button class="m-btn" onclick="recalibrateToStage(1)">回到阶段1</button>
      <button class="m-btn" onclick="recalibrateToStage(2)">回到阶段2</button>
      <button class="m-btn" onclick="recalibrateToStage(3)">回到阶段3</button>
    </div></div>`;
  document.body.appendChild(modal);
}

function recalibrateToStage(n){
  // 关闭所有 modal
  document.querySelectorAll('.mo').forEach(m=>m.remove());
  // 回退到指定阶段
  setStage(n);
  // 提示 AI：用户想重新校准
  const stageNames=['','用户画像','项目理解','工具架构','自动化策略'];
  S._recalibrateHint=`\n\n=== 罗盘校准 ===\n用户主动回到阶段${n}（${stageNames[n]}），希望调整前序信息。\n保留已有的 CLAUDE.md 作为参考，请基于用户的新输入重新生成 CLAUDE.md。\n不要简单复制旧版，要根据用户的调整意见有针对性修改。`;
  addSysMsg(`🧭 已回到阶段${n}：${stageNames[n]}，请告诉我你想调整什么`);
}

function addRecalibrateButtons(){
  // 非阻塞：在聊天区追加一组按钮，引导用户重新校准
  const chat=document.getElementById('chat');
  const wrap=document.createElement('div');
  wrap.className='msg-row';
  wrap.innerHTML=`<div class="bubble" style="max-width:75%;font-size:12px;color:var(--text2)">
    <div style="margin-bottom:6px">🧭 <b>方向校准</b> — 对生成的 CLAUDE.md 不满意？</div>
    <div style="display:flex;gap:5px;flex-wrap:wrap">
      <button class="pb-act" onclick="recalibrateToStage(1)">调整用户画像</button>
      <button class="pb-act" onclick="recalibrateToStage(2)">调整项目理解</button>
      <button class="pb-act" onclick="recalibrateToStage(3)">调整自动化策略</button>
      <button class="pb-act ok" onclick="this.closest('.msg-row').remove()">继续 → 提取 skill</button>
    </div>
  </div>`;
  chat.appendChild(wrap);
  chat.scrollTop=chat.scrollHeight;
}

function addSysMsg(text){
  const chat=document.getElementById('chat');
  const el=document.createElement('div');
  el.className='sys-msg';el.textContent=text;
  chat.appendChild(el);chat.scrollTop=chat.scrollHeight;
}

function showTyping(){
  const chat=document.getElementById('chat');
  const row=document.createElement('div');row.className='msg-row';row.id='typing';
  const av=document.createElement('div');av.className='av ai';av.textContent='AI';
  const bub=document.createElement('div');bub.className='bubble';
  bub.innerHTML='<div class="dots"><span></span><span></span><span></span></div>';
  row.appendChild(av);row.appendChild(bub);chat.appendChild(row);
  chat.scrollTop=chat.scrollHeight;
}
function removeTyping(){document.getElementById('typing')?.remove();}

function md(t){
  return String(t)
    .replace(/&(?!amp;|lt;|gt;)/g,'&amp;')
    .replace(/\*\*(.*?)\*\*/g,'<b>$1</b>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\n/g,'<br>');
}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ====== FILE UPLOAD ======
async function processUploadedFile(file){
  if(!file) return;
  if(file.size > 2*1024*1024){ addSysMsg(t('msg.fileTooBig')); return; }
  const ext = file.name.split('.').pop().toLowerCase();
  let text = '';
  try {
    if(ext === 'docx'){
      if(typeof mammoth === 'undefined'){ addSysMsg('⚠ mammoth.js 未加载，无法解析 docx，请改用 txt 格式'); return; }
      const buf = await file.arrayBuffer();
      const result = await mammoth.extractRawText({arrayBuffer: buf});
      text = result.value;
      if(!text.trim()){ addSysMsg(t('msg.docxEmpty')); return; }
    } else {
      text = await new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = e => resolve(e.target.result);
        reader.onerror = () => reject(new Error('read error'));
        reader.readAsText(file);
      });
    }
  } catch(e){
    if(ext === 'docx') addSysMsg(t('msg.docxParseError'));
    else addSysMsg(t('msg.fileReadError'));
    return;
  }
  const inp = document.getElementById('inp');
  if(!inp) return;
  const current = inp.value.trim();
  inp.value = current ? current + '\n\n---\n' + file.name + '\n---\n' + text : text;
  autoResize(inp);
  addSysMsg(t('msg.fileLoaded',{name:file.name, size:(file.size/1024).toFixed(1)}));
}

function handleFileUpload(event){
  const file = event.target.files[0];
  processUploadedFile(file);
  // 重置 file input，允许重复上传同一文件
  event.target.value = '';
}

// ====== DRAG & DROP ======
let _dragCounter = 0;
function setupDragDrop(){
  const overlay = document.getElementById('dragOverlay');
  if(!overlay) return;
  const handlers = {
    dragenter(e){ e.preventDefault(); e.stopPropagation(); _dragCounter++; overlay.classList.add('show'); },
    dragleave(e){ e.preventDefault(); e.stopPropagation(); _dragCounter--; if(_dragCounter <= 0){ _dragCounter = 0; overlay.classList.remove('show'); } },
    dragover(e){ e.preventDefault(); e.stopPropagation(); },
    drop(e){
      e.preventDefault(); e.stopPropagation();
      _dragCounter = 0; overlay.classList.remove('show');
      const file = e.dataTransfer?.files?.[0];
      if(!file) return;
      processUploadedFile(file);
    }
  };
  ['dragenter','dragleave','dragover','drop'].forEach(evt => {
    document.addEventListener(evt, handlers[evt]);
  });
}

// ====== SEND ======
function handleKey(e){if(e.key==='Enter'&&(e.shiftKey||e.ctrlKey||e.metaKey)){e.preventDefault();sendMessage();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,130)+'px';}

async function sendMessage(){
  if(!S.provider){alert(t('alert.selectAiProviderFirst'));return;}
  const key=S.apiKeys[S.provider.id];
  if(!key){alert(t('alert.configureApiKey'));return;}
  const model=getActiveModel();
  if(!model){alert(t('alert.selectModel'));return;}

  const inp=document.getElementById('inp');
  const text=inp.value.trim();
  if(!text||S.loading) return;
  inp.value='';inp.style.height='auto';
  const userIdx=S.history.length;
  addMsg('human',text,userIdx);
  S.history.push({role:'user',content:text});
  // 历史记录上限：超过 MAX_HISTORY 条时删除最早的 50 条
  if(S.history.length > MAX_HISTORY){
    S.history = S.history.slice(50);
  }

  S.loading=true;document.getElementById('sendBtn').disabled=true;showTyping();

  try{
    const p=S.provider;
    let sys=S.systemPrompt+(S.locale==='zh'?
      `\n\n当前自动化模式：${S.mode}。当前所处阶段：${S.stage}`:
      `\n\nCurrent automation mode: ${S.mode}. Current stage: ${S.stage}`);
    // 注入重新校准提示
    if(S._recalibrateHint){
      sys+=S._recalibrateHint;
      S._recalibrateHint=null;
    }
    // 注入用户个人偏好
    if(S.localMd && S.localMd.trim()){
      sys+=`\n\n=== 用户个人偏好（将写入 CLAUDE.local.md） ===\n${S.localMd}\n生成 CLAUDE.md 时请参考以上偏好调整指令风格。`;
    }
    // 注入学习调整（基于历史反馈）
    const learningAdj = getLearningAdjustments(p.id, model);
    if(learningAdj) sys += learningAdj;
    // 注入提供商差异补偿（promptPatch）
    if(p.promptPatch) sys += p.promptPatch;
    // 后续阶段附加上下文，确保 AI 基于已生成内容工作
    if(S.claudeMd){
      sys+=`\n\n=== 已生成的 CLAUDE.md（后续阶段需严格基于此内容工作） ===\n${S.claudeMd}`;
    }
    if(S.skillMd){
      sys+=`\n\n=== 已生成的 SKILL.md ===\n${S.skillMd}`;
    }
    let body=p.buildBody(S.history,sys,model,key);
    let url=p.customUrl&&body._url?body._url:p.baseUrl;
    if(body._url) delete body._url;
    if(p.id==='custom'){
      const cu=document.getElementById('baseUrlInput').value.trim();
      if(cu) url=cu;
    }

    // 超时处理：120 秒
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 120000);
    const res=await fetch(url,{method:'POST',headers:p.headers(key),body:JSON.stringify(body),signal:controller.signal});
    clearTimeout(timeout);
    if(!res.ok){const err=await res.text();throw new Error(httpErrorMsg(res.status, err));}
    const data=await res.json();
    const reply=p.parseReply(data);
    if(!reply) throw new Error('空回复，请检查 Key / 模型 / 余额');
    // 提供商差异补偿：预处理回复（去除多余段落、补漏 [STAGE:N] 等）
    const cleanReply = p.preprocessReply ? p.preprocessReply(reply) : reply;
    S.history.push({role:'assistant',content:cleanReply});
    removeTyping();renderReply(cleanReply,S.history.length-1);
    autoSaveProject();
  }catch(e){
    removeTyping();
    const msg = e.name === 'AbortError' ? '请求超时（120秒），请稍后重试或切换模型' : e.message;
    addMsg('ai',t('error.aiRequest',{msg}));
    autoSaveProject();
  }
  S.loading=false;document.getElementById('sendBtn').disabled=false;
}

// 合并 skill XML：同名则替换，否则追加
function mergeSkill(existing, newXml){
  const nameMatch = newXml.match(/<name>([^<]*)<\/name>/);
  if(!nameMatch) return existing ? existing + '\n\n' + newXml : newXml;
  const skillName = nameMatch[1];
  if(!existing) return newXml;
  const escaped = skillName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const re = new RegExp(`<skill>[\\s\\S]*?<name>${escaped}</name>[\\s\\S]*?</skill>`, 'i');
  if(re.test(existing)) return existing.replace(re, newXml);
  return existing + '\n\n' + newXml;
}

// ====== FEEDBACK & LEARNING SYSTEM ======
function getFeedback(){
  try{ return JSON.parse(localStorage.getItem('csg_feedback')||'[]'); }catch(e){ return []; }
}

function saveFeedbackEntry(entry){
  const all = getFeedback();
  // 检测重建：同一项目同一文件类型之前的生成记录标记为"被重建"
  const sameType = all.filter(f =>
    f.project_id === entry.project_id &&
    f.type === entry.type &&
    !f.regenerated
  );
  if(sameType.length > 0){
    sameType[sameType.length-1].regenerated = true;
    sameType[sameType.length-1].regenerated_at = Date.now();
  }
  all.push(entry);
  try{ localStorage.setItem('csg_feedback', JSON.stringify(all)); }catch(e){}
  // 更新学习统计展示
  updateLearningStats(entry.provider, entry.model);
  return all.length;
}

function getFeedbackStats(provider, model){
  const all = getFeedback().filter(f => f.provider === provider && f.model === model);
  const total = all.length;
  const rated = all.filter(f => f.rating > 0);
  const avgRating = rated.length > 0 ? (rated.reduce((s,f) => s+f.rating, 0) / rated.length).toFixed(1) : 'N/A';
  const regenerated = all.filter(f => f.regenerated).length;
  const byType = {};
  all.forEach(f => {
    if(!byType[f.type]) byType[f.type] = {total:0, ratings:[], regenerated:0};
    byType[f.type].total++;
    if(f.rating > 0) byType[f.type].ratings.push(f.rating);
    if(f.regenerated) byType[f.type].regenerated++;
  });
  // 常见原因关键词统计
  const keywords = {};
  all.filter(f => f.reason).forEach(f => {
    f.reason.toLowerCase().split(/[\s,，、。]+/).filter(w => w.length >= 2).forEach(w => {
      keywords[w] = (keywords[w]||0) + 1;
    });
  });
  const topKeywords = Object.entries(keywords).sort((a,b) => b[1]-a[1]).slice(0,10);
  return {total, rated: rated.length, avgRating, regenerated, byType, topKeywords};
}

function getLearningAdjustments(provider, model){
  const stats = getFeedbackStats(provider, model);
  if(stats.total < 20) return ''; // 不足20条，不调整
  let adj = '\n\n=== 学习调整（基于历史反馈自动追加） ===\n';
  adj += `已积累 ${stats.total} 条反馈，平均评分：${stats.avgRating}/5\n`;

  // 高重建率 →提示增加确认环节
  const claudeStats = stats.byType['claude'];
  const skillStats = stats.byType['skill'];
  if(claudeStats && claudeStats.regenerated/claudeStats.total > 0.3){
    adj += '- CLAUDE.md 重建率高（>30%），建议在阶段4增加更多细节确认\n';
  }
  if(skillStats && skillStats.regenerated/skillStats.total > 0.3){
    adj += '- SKILL.md 重建率高（>30%），建议在阶段5触发条件部分更加审慎\n';
  }

  // 低评分 →提示侧重方向
  if(stats.rated > 5 && parseFloat(stats.avgRating) < 3.5){
    adj += '- 整体评分偏低（<3.5），建议生成时更注重具体性、减少泛泛填充\n';
  }

  // 高频反馈关键词
  if(stats.topKeywords.length > 0){
    const relevant = stats.topKeywords.filter(([w]) =>
      ['太宽泛','不具体','不准确','太长','太短','缺少','重复','冲突','模糊','不清楚'].includes(w)
    );
    if(relevant.length > 0){
      adj += `- 常见问题关键词：${relevant.map(([w,c]) => `"${w}"(${c}次)`).join('、')}\n`;
    }
  }

  adj += '以上调整基于当前模型和项目类型的反馈数据，请结合本次生成场景自行判断。\n';
  return adj;
}

function showFeedbackModal(type){
  const p = S.provider;
  const model = getActiveModel();
  const provider = p ? p.id : 'unknown';
  const overlay = document.createElement('div');
  overlay.className = 'mo';
  overlay.id = 'feedbackModal';
  overlay.onclick = e => { if(e.target === overlay) overlay.remove(); };

  let starsHtml = '';
  for(let i=1; i<=5; i++){
    starsHtml += `<span class="star" data-v="${i}" onmouseover="highlightStars(${i})" onmouseout="resetStars()" onclick="setStarRating(${i})">★</span>`;
  }

  overlay.innerHTML = `<div class="mb" style="width:420px">
    <div class="mh">
      <div class="mt">📊 质量评分（可选）</div>
      <button class="mc-btn" onclick="document.getElementById('feedbackModal').remove()">×</button>
    </div>
    <div class="mc" style="white-space:normal;font-family:var(--sans);font-size:12px;line-height:1.8">
      <div style="color:var(--text2);margin-bottom:6px">刚下载了 <b>${esc(type==='claude'?'CLAUDE.md':'SKILL.md')}</b>，觉得质量如何？</div>
      <div style="font-size:10px;color:var(--text3)">反馈帮助生成器在同类项目上越做越好</div>
      <div class="star-rating" id="starRating">${starsHtml}</div>
      <div class="rating-score" id="ratingScore"></div>
      <textarea class="feedback-reason" id="feedbackReason" placeholder="哪些地方好、哪些不好？（选填）"></textarea>
    </div>
    <div class="mf">
      <button class="m-btn pri" id="feedbackSubmit" onclick="submitFeedback('${type}','${provider}','${model}')" disabled>提交评分</button>
      <button class="m-btn" onclick="document.getElementById('feedbackModal').remove()">跳过</button>
    </div>
  </div>`;
  document.body.appendChild(overlay);

  // 临时状态
  window._feedbackRating = 0;
  window.highlightStars = function(n){
    const stars = document.querySelectorAll('#starRating .star');
    stars.forEach((s,i) => { s.classList.toggle('active', i < n); });
  };
  window.resetStars = function(){
    const stars = document.querySelectorAll('#starRating .star');
    stars.forEach((s,i) => { s.classList.toggle('active', i < window._feedbackRating); });
  };
  window.setStarRating = function(n){
    window._feedbackRating = n;
    resetStars();
    document.getElementById('ratingScore').textContent = `${n} / 5 分`;
    document.getElementById('feedbackSubmit').disabled = false;
  };
}

window.submitFeedback = function(type, provider, model){
  const rating = window._feedbackRating;
  const reason = document.getElementById('feedbackReason')?.value?.trim() || '';
  if(rating <= 0) return;

  const projId = getActiveProjId();
  const proj = getProjects().find(p => p.id === projId);
  const entry = {
    id: 'fb_' + Date.now(),
    type: type,           // 'claude' | 'skill'
    provider: provider,
    model: model,
    project_id: projId,
    project_name: proj ? proj.name : '未知',
    rating: rating,
    reason: reason,
    regenerated: false,
    timestamp: Date.now()
  };
  const total = saveFeedbackEntry(entry);
  const modal = document.getElementById('feedbackModal');
  if(modal) modal.remove();
  addSysMsg(t('msg.feedbackThanks',{total, extra: total>=20?t('msg.feedbackLearningActive'):''}));
  delete window._feedbackRating;
  delete window.highlightStars;
  delete window.resetStars;
  delete window.setStarRating;
};

function updateLearningStats(provider, model){
  const stats = getFeedbackStats(provider, model);
  if(stats.total < 20) return; // 不足20条不显示
  const el = document.getElementById('learningStats');
  if(!el){
    const outSec = document.querySelector('.out-sec');
    const div = document.createElement('div');
    div.id = 'learningStats';
    div.className = 'learning-stats';
    outSec.insertBefore(div, outSec.firstChild);
  }
  const d = document.getElementById('learningStats');
  if(d){
    d.innerHTML = `🧠 学习数据：${stats.total}条 · 均分${stats.avgRating} · 重建率${stats.regenerated>0?(stats.regenerated/stats.total*100).toFixed(0)+'%':'0%'}`;
    d.title = `已评分${stats.rated}条，来自${provider}/${model}`;
  }
}

function initLearningStats(){
  const p = S.provider;
  const model = getActiveModel();
  if(p && model) updateLearningStats(p.id, model);
}

// ====== SKILL 触发验证清单 ======
function generateSkillChecklist(skillMd){
  if(!skillMd) return null;
  const skills = [];
  const re = /<skill>[\s\S]*?<\/skill>/gi;
  let m;
  while((m = re.exec(skillMd)) !== null){
    const xml = m[0];
    const name = (xml.match(/<name>([^<]*)<\/name>/i)||[])[1]||'未知';
    const desc = (xml.match(/<description>([^<]*)<\/description>/i)||[])[1]||'';
    const triggers = []; const triggerRe = /<trigger>([^<]*)<\/trigger>/gi; let tm;
    while((tm = triggerRe.exec(xml)) !== null) triggers.push(tm[1]);
    const antiTriggers = []; const atRe = /<anti-trigger>([^<]*)<\/anti-trigger>/gi; let am;
    while((am = atRe.exec(xml)) !== null) antiTriggers.push(am[1]);
    skills.push({name, desc, triggers, antiTriggers});
  }
  if(skills.length === 0) return null;

  const issues = [];
  // 检查每个 skill
  skills.forEach((sk, idx) => {
    const prefix = `[${sk.name}]`;

    // 1. 触发条件是否足够具体
    const broadPatterns = [/文件操作/, /代码/, /项目/, /开发/, /涉及.*时/, /需要.*时/, /用户.*时/];
    sk.triggers.forEach(t => {
      broadPatterns.forEach(bp => {
        if(bp.test(t) && t.length < 20){
          issues.push({severity:'高', skill:sk.name, check:'触发条件具体性', detail:`"${t}" 太宽泛，可能被所有任务触发。建议加入具体关键词或操作描述`});
        }
      });
    });
    if(sk.triggers.length === 0){
      issues.push({severity:'高', skill:sk.name, check:'触发条件缺失', detail:'没有任何触发条件，skill 永远不会被调用'});
    }

    // 2. 反触发条件是否明确（至少2个）
    if(sk.antiTriggers.length === 0){
      issues.push({severity:'高', skill:sk.name, check:'反触发条件缺失', detail:'没有反触发条件。建议至少补充2个"不用此skill"的场景'});
    } else if(sk.antiTriggers.length < 2){
      issues.push({severity:'中', skill:sk.name, check:'反触发条件不足', detail:`仅有${sk.antiTriggers.length}个反触发条件，建议至少2个`});
    }

    // 3. 反触发是否和触发矛盾
    if(sk.triggers.length > 0 && sk.antiTriggers.length > 0){
      sk.antiTriggers.forEach(at => {
        sk.triggers.forEach(t => {
          if(at.toLowerCase().includes(t.toLowerCase()) || t.toLowerCase().includes(at.toLowerCase())){
            issues.push({severity:'高', skill:sk.name, check:'触发/反触发矛盾', detail:`触发"${t}" 与反触发"${at}" 可能互相矛盾`});
          }
        });
      });
    }
  });

  // 4. 跨 skill 触发条件重叠
  for(let i=0; i<skills.length; i++){
    for(let j=i+1; j<skills.length; j++){
      const si = skills[i], sj = skills[j];
      si.triggers.forEach(ti => {
        sj.triggers.forEach(tj => {
          const overlap = ti.toLowerCase().includes(tj.toLowerCase()) || tj.toLowerCase().includes(ti.toLowerCase());
          if(overlap && ti.length > 5 && tj.length > 5){
            issues.push({severity:'中', skill:`${si.name} ⇄ ${sj.name}`, check:'触发条件重叠', detail:`"${ti}" 与 "${tj}" 可能重叠，AI 不知道该调用哪个 skill`});
          }
        });
      });
    }
  }

  // 5. 检查是否有内置行为冲突的关键词
  const builtinKeywords = ['claude.md', 'claude code', 'settings.json', 'keybindings', '/compact', '/clear'];
  skills.forEach(sk => {
    sk.triggers.forEach(t => {
      builtinKeywords.forEach(bk => {
        if(t.toLowerCase().includes(bk.toLowerCase())){
          issues.push({severity:'低', skill:sk.name, check:'内置行为重叠', detail:`触发条件包含 "${bk}"，可能与 Claude Code 默认行为冲突`});
        }
      });
    });
  });

  return {skills: skills.map(s => s.name), totalSkills: skills.length, issues};
}

// ====== 生成后自检 ======
function generateSelfCheck(claudeMd, skillMd){
  const issues = [];

  // 1. CLAUDE.md 约束冲突检测
  const modeMatch = claudeMd.match(/MODE:\s*(\w+)/);
  const mode = modeMatch ? modeMatch[1] : '';
  const interventionSection = claudeMd.match(/INTERVENTION_POINTS:([\s\S]*?)(?=\n##|\n#|$)/);
  const interventions = interventionSection ? (interventionSection[1].match(/- \[[ x]\]/g)||[]) : [];

  // full_auto 模式但有过多干预节点
  if(mode === 'full_auto' && interventions.length > 3){
    issues.push({severity:'中', file:'CLAUDE.md', check:'模式与干预节点不匹配', detail:`MODE 设为 full_auto 但有 ${interventions.length} 个干预节点，全自动模式通常只需0-2个`});
  }
  // manual 模式但没有干预节点
  if(mode === 'manual' && interventions.length === 0){
    issues.push({severity:'低', file:'CLAUDE.md', check:'干预节点缺失', detail:'manual 模式下建议至少列出1个干预节点说明何时介入'});
  }

  // 2. [待确认] 字段检测
  const pendingMatches = claudeMd.match(/\[待确认\]/g);
  if(pendingMatches && pendingMatches.length > 0){
    issues.push({severity:'高', file:'CLAUDE.md', check:'存在未确认字段', detail:`${pendingMatches.length} 处 [待确认] 标记，建议确认后再导出使用`});
  }

  // 3. Tech Stack 章节完整性
  if(!/## Tech Stack/.test(claudeMd)){
    issues.push({severity:'中', file:'CLAUDE.md', check:'Tech Stack 章节缺失', detail:'建议补充技术栈信息，方便后续协作时 AI 了解项目环境'});
  } else {
    const tsSection = claudeMd.match(/## Tech Stack([\s\S]*?)(?=\n##|\n#|$)/);
    if(tsSection && tsSection[1].trim().length < 15){
      issues.push({severity:'低', file:'CLAUDE.md', check:'Tech Stack 内容过简', detail:'技术栈描述太简略，建议至少列出语言、框架、部署方式'});
    }
  }

  // 4. Commands 章节完整性
  if(!/## Commands/.test(claudeMd)){
    issues.push({severity:'中', file:'CLAUDE.md', check:'Commands 章节缺失', detail:'缺少常用命令，skill 将无法引用具体操作'});
  }

  // 5. 跨文件一致性：SKILL.md 引用的 CLAUDE.md 章节
  const refRegex = /<claude-md-section>([^<]*)<\/claude-md-section>/gi;
  let rm;
  while((rm = refRegex.exec(skillMd)) !== null){
    const ref = rm[1].trim();
    if(ref && !claudeMd.includes(ref)){
      issues.push({severity:'中', file:'SKILL.md', check:'引用章节不存在', detail:`引用了 CLAUDE.md 的"${ref}"，但该章节在 CLAUDE.md 中不存在`});
    }
  }

  // 6. SKILL.md 与 CLAUDE.md 中的命令对应
  const cmdSection = claudeMd.match(/## Commands([\s\S]*?)(?=\n##|\n#|$)/);
  if(cmdSection){
    const commands = cmdSection[1].match(/`([^`]+)`/g)||[];
    const skillMentions = commands.filter(cmd => skillMd.includes(cmd.replace(/`/g,'')));
    if(commands.length > 0 && skillMentions.length === 0){
      issues.push({severity:'低', file:'SKILL.md', check:'命令未复用', detail:`CLAUDE.md 定义了 ${commands.length} 条命令，但 SKILL.md 未引用任何一条`});
    }
  }

  // 7. User Profile 章节检查（新增关键章节）
  if(!/## User Profile/.test(claudeMd)){
    issues.push({severity:'高', file:'CLAUDE.md', check:'User Profile 章节缺失', detail:'缺少用户画像，Claude Code 无法知道用户的水平、偏好和痛点，这是最重要的上下文'});
  } else {
    const upSection = claudeMd.match(/## User Profile[\s\S]*?(?=\n##|\n#|$)/);
    if(upSection && upSection[0].length < 60){
      issues.push({severity:'中', file:'CLAUDE.md', check:'User Profile 内容过简', detail:'用户画像太简略，建议至少包含技术水平、沟通偏好、AI 协作痛点'});
    }
  }

  // 8. AI 协作禁忌章节检查（新增关键章节）
  if(!/## AI 协作禁忌/.test(claudeMd)){
    issues.push({severity:'中', file:'CLAUDE.md', check:'AI 协作禁忌 章节缺失', detail:'缺少 AI 行为边界定义，Claude Code 可能做出不符合用户期望的操作'});
  }

  // 9. Overview 与 SKILL 的一致性
  const overview = claudeMd.match(/## Overview\n([^\n]+)/);
  const skillCount = (skillMd.match(/<skill>/gi)||[]).length;
  if(overview && skillCount === 0){
    issues.push({severity:'低', file:'SKILL.md', check:'未提取 skill', detail:'CLAUDE.md 有项目描述但未提取任何 skill，确认项目中真的没有可自动化的操作吗？'});
  }

  // 10. CLAUDE.md 文件大小检查（新增：memory 文档建议≤200行）
  const claudeLines = claudeMd.split('\n').length;
  if(claudeLines > 300){
    issues.push({severity:'高', file:'CLAUDE.md', check:'文件过大', detail:`${claudeLines} 行，远超 200 行建议。强烈建议拆分为 .claude/rules/ 路径作用域规则文件`});
  } else if(claudeLines > 200){
    issues.push({severity:'中', file:'CLAUDE.md', check:'文件偏大', detail:`${claudeLines} 行，超过 200 行建议。考虑将部分内容拆分为 .claude/rules/ 模块`});
  }

  // 11. @import 使用建议（新增）
  if(!/^@\S/.test(claudeMd.trim()) && claudeLines > 40){
    issues.push({severity:'低', file:'CLAUDE.md', check:'未使用 @import', detail:'如果项目有 README.md 或 package.json，可用 @README.md 导入避免重复'});
  }

  // 12. 运行架构章节检查（新增：双模型用户关键信息）
  if(!/## 运行架构/.test(claudeMd)){
    issues.push({severity:'低', file:'CLAUDE.md', check:'运行架构 章节缺失', detail:'如果使用 Claude Code + 其他模型的组合架构，建议写明以帮助 AI 调整输出风格'});
  }

  // 13. .claude/rules/ 拆分建议（新增）
  const sectionCount = (claudeMd.match(/^## /gm)||[]).length;
  if(sectionCount >= 10 && claudeLines > 150){
    issues.push({severity:'中', file:'CLAUDE.md', check:'建议拆分为 rules', detail:`${sectionCount} 个章节，建议将部分内容移入 .claude/rules/ 目录按路径作用域管理`});
  }

  // 14. CLAUDE.local.md 提醒（新增）
  if(!/CLAUDE\.local\.md/.test(claudeMd)){
    issues.push({severity:'低', file:'CLAUDE.md', check:'未提及 CLAUDE.local.md', detail:'建议在文件中提醒用户可创建 CLAUDE.local.md（gitignored）存放个人偏好，如本地测试数据、sandbox URL 等'});
  }

  return {totalChecks: 14, issues};
}

function renderSelfCheck(selfCheck, container){
  const {issues} = selfCheck;
  const highIssues = issues.filter(i => i.severity === '高');
  const medIssues = issues.filter(i => i.severity === '中');

  const card = document.createElement('div');
  card.className = 'patch-card';
  card.id = 'selfCheck';
  card.style.marginTop = '9px';
  card.style.borderColor = highIssues.length > 0 ? 'rgba(248,113,113,0.5)' : 'var(--border2)';

  let issuesHtml = issues.map(iss => {
    const sevColor = {高:'var(--red)',中:'var(--amber)',低:'var(--blue)'}[iss.severity]||'var(--text2)';
    const sevBg = {高:'rgba(248,113,113,0.12)',中:'rgba(251,191,36,0.12)',低:'rgba(96,165,250,0.08)'}[iss.severity]||'rgba(255,255,255,0.05)';
    return `<div style="padding:5px 10px;margin:2px 0;border-radius:5px;background:${sevBg};font-size:11px">
      <span style="color:${sevColor};font-weight:600;font-size:10px">● ${iss.severity}</span>
      <span style="color:var(--text2)"> [${esc(iss.file)}] ${esc(iss.check)}</span>
      <span style="color:var(--text3);margin-left:4px">— ${esc(iss.detail)}</span>
    </div>`;
  }).join('');

  card.innerHTML = `
    <div class="patch-head">
      <span class="patch-field">🔎 生成后自检</span>
      <span style="font-size:10px;color:var(--text3)">${issues.length} 个问题 · ${highIssues.length}高 ${medIssues.length}中</span>
    </div>
    <div class="patch-body">
      <div style="color:var(--text2);font-size:11px;margin-bottom:4px">
        检查维度：用户画像 · 约束冲突 · 字段完整性 · 跨文件引用 · 命令复用 · 干预覆盖 · AI协作禁忌 · 文件大小 · @import · rules拆分 · 双模型架构
      </div>
      ${issuesHtml}
    </div>
    <div class="patch-acts">
      ${highIssues.length > 0 ? '<span style="color:var(--red);font-size:10px;padding:5px">⚠ 存在高风险问题，请修正后再导出</span>' : '<span style="color:var(--green);font-size:10px;padding:5px">✓ 未发现高风险问题</span>'}
    </div>`;
  container.appendChild(card);
  card.scrollIntoView({behavior:'smooth',block:'center'});
}

function renderSkillChecklist(checklist, container){
  if(!checklist) return;
  const {skills, totalSkills, issues} = checklist;
  const highIssues = issues.filter(i => i.severity === '高');
  const medIssues = issues.filter(i => i.severity === '中');
  const lowIssues = issues.filter(i => i.severity === '低');

  const card = document.createElement('div');
  card.className = 'patch-card';
  card.id = 'skillChecklist';
  card.style.marginTop = '9px';

  let issuesHtml = '';
  if(issues.length === 0){
    issuesHtml = '<div style="color:var(--green);padding:8px;font-size:11px">✓ 所有检查通过，未发现问题</div>';
  } else {
    issues.forEach(iss => {
      const sevColor = {高:'var(--red)',中:'var(--amber)',低:'var(--blue)'}[iss.severity]||'var(--text2)';
      const sevBg = {高:'rgba(248,113,113,0.15)',中:'rgba(251,191,36,0.15)',低:'rgba(96,165,250,0.15)'}[iss.severity]||'rgba(255,255,255,0.05)';
      issuesHtml += `<div style="padding:6px 10px;margin:3px 0;border-radius:6px;background:${sevBg};font-size:11px">
        <span style="color:${sevColor};font-weight:600;font-family:var(--mono);font-size:10px">${iss.severity}</span>
        <span style="color:var(--accent);font-family:var(--mono);margin:0 6px">${esc(iss.skill)}</span>
        <span style="color:var(--text2)">[${esc(iss.check)}]</span>
        <span style="color:var(--text3);margin-left:4px">${esc(iss.detail)}</span>
      </div>`;
    });
  }

  card.innerHTML = `
    <div class="patch-head">
      <span class="patch-field">🔍 SKILL 触发验证清单</span>
      <span style="font-size:10px;color:var(--text3)">${totalSkills} 个 skill · ${highIssues.length}高 ${medIssues.length}中 ${lowIssues.length}低</span>
    </div>
    <div class="patch-body">
      <div style="color:var(--text2);font-size:11px;margin-bottom:6px">
        <b>已验证 Skill：</b>${skills.map(s => `<code style="font-size:10px">${esc(s)}</code>`).join(' ')}
      </div>
      <div style="font-size:10px;color:var(--text3);margin-bottom:4px">
        □ 触发条件具体性  □ 反触发条件明确  □ 触发/反触发矛盾  □ 跨skill重叠  □ 内置行为冲突
      </div>
      ${issuesHtml}
    </div>
    <div class="patch-acts">
      ${highIssues.length > 0 ? '<span style="color:var(--red);font-size:10px;padding:5px">⚠ 存在高风险问题，建议修正后再导出</span>' : ''}
      ${highIssues.length === 0 && medIssues.length > 0 ? '<span style="color:var(--amber);font-size:10px;padding:5px">⚡ 存在中风险问题，请留意</span>' : ''}
    </div>`;
  container.appendChild(card);
  card.scrollIntoView({behavior:'smooth',block:'center'});
}

function renderReply(text,aiIdx){
  const sm=text.match(/\[STAGE:(\d)\]/);if(sm) setStage(parseInt(sm[1]));

  // 提取代码块（与显示替换用同一正则，确保显示即捕获）
  const codeBlocks = [];
  const cbRe = /```(?:markdown|xml|bash)?[\s\S]*?```/g;
  let cbMatch;
  while((cbMatch = cbRe.exec(text)) !== null){
    const full = cbMatch[0];
    let inner = full.replace(/```(?:markdown|xml|bash)?\s*\n?/,'');
    inner = inner.replace(/\n?\s*```$/,'').trim();
    codeBlocks.push({full, inner});
  }
  let cm = null;
  const allSkillBlocks = []; // 收集所有 skill 代码块
  for(const block of codeBlocks){
    if(!cm && (block.inner.startsWith('# Project') || block.inner.startsWith('#\x20Project'))){
      cm = [block.full, block.inner];
    }
    if(block.inner.startsWith('<skill')){
      allSkillBlocks.push(block);
    }
  }
  
  // 对比模式：如果已有内容且新内容不同，暂存并展示对比
  if(cm&&S.mode==='compare'&&S.claudeMd&&cm[1].trim()!==S.claudeMd){
    S._pendingClaudeMd=cm[1].trim();
  } else if(cm){
    S._prevClaudeMd=S.claudeMd;
    S.claudeMd=cm[1].trim();
    S._justGenerated='claude';
    updateFileCards();
  }
  // 处理所有 skill 代码块
  const hasNewSkills = allSkillBlocks.length > 0;
  if(hasNewSkills){
    if(S.mode==='compare' && S.skillMd){
      // 对比模式：检查是否有新内容
      const allNewSkills = allSkillBlocks.map(b => b.inner).join('\n\n');
      if(allNewSkills.trim() !== S.skillMd.trim()){
        S._pendingSkillMd = allNewSkills.trim();
      }
    } else {
      // 普通模式：逐个合并所有 skill
      S._prevSkillMd = S.skillMd;
      for(const block of allSkillBlocks){
        S.skillMd = mergeSkill(S.skillMd, block.inner.trim());
      }
      S._justGenerated = 'skill';
      updateFileCards();
    }
  }
  if(cm||hasNewSkills){ saveFiles(); }
  // 全自动模式：生成后自动下载文件
  if(S.mode==='full_auto'){
    if(cm) setTimeout(() => dlFile('claude'), 400);
    if(hasNewSkills) setTimeout(() => dlFile('skill'), 700);
  }

  // 如果同时提取到了 SKILL.md，确保阶段至少推进到 4
  if(S.skillMd && S.stage < 5) setStage(5);
  // 如果提取到了 CLAUDE.md 但没有 SKILL.md，确保阶段至少推进到 4
  if(S.claudeMd && !S.skillMd && S.stage < 4) setStage(4);

  const patches=[];
  const pr=/^\{[^{}\n]*"patch_id"[^{}\n]*\}$/gm;let pm;
  while((pm=pr.exec(text))!==null){try{patches.push(JSON.parse(pm[0]));}catch(e){}}

  let display=text
    .replace(/\[STAGE:\d\]/g,'')
    .replace(/```(?:markdown|xml|bash)?[\s\S]*?```/g,cb=>{
      const inner=cb.replace(/```(?:markdown|xml|bash)?/,'').replace(/```$/,'').trim();
      if(inner.startsWith('#\x20Project')) return '[📄 CLAUDE.md 已生成 — 点击左侧预览]';
      if(inner.startsWith('<skill')) return '[🔧 SKILL.md 已生成 — 点击左侧预览]';
      return `<pre>${esc(inner)}</pre>`;
    })
    .replace(/^\{[^{}\n]*"patch_id"[^{}\n]*\}$/gm,'').trim();

  const bub=addMsg('ai',display||'（文件已生成，请点击左侧预览）',aiIdx);

  // 对比模式：渲染文件对比卡片
  if(S._pendingClaudeMd) renderFileCompare('claude',S.claudeMd,S._pendingClaudeMd,bub);
  if(S._pendingSkillMd) renderFileCompare('skill',S.skillMd,S._pendingSkillMd,bub);

  if(patches.length){
    if(S.mode==='full_auto'){patches.forEach(p=>{autoApply(p);});addSysMsg(t('msg.fullAutoPatches',{count:patches.length}));}
    else patches.forEach(p=>renderPatch(p,bub));
  }

  // SKILL.md 更新后，自动生成触发验证清单
  if(hasNewSkills){
    const checklist = generateSkillChecklist(S.skillMd);
    if(checklist) renderSkillChecklist(checklist, bub);
  }

  // 两个文件都就绪时，触发生成后自检
  if(S.claudeMd && S.skillMd && (cm || hasNewSkills)){
    const selfCheck = generateSelfCheck(S.claudeMd, S.skillMd);
    if(selfCheck && selfCheck.issues.length > 0) renderSelfCheck(selfCheck, bub);
  }

  // Check模式：阶段推进后暂停提醒
  if(sm && S.mode==='checkpoint'){
    // stage names now via t('stage.reply.N') for i18n
    const markerStage=parseInt(sm[1]);
    const actualStage=S.stage;
    // 用实际推进到的阶段显示暂停消息
    const displayStage=actualStage>=1?actualStage:markerStage;
    if(displayStage>=1 && displayStage<=5){
      // 如果阶段被自动推进了（比如同时生成了两个文件），合并提示
      if(actualStage>markerStage && markerStage>=3 && actualStage>=4){
        addSysMsg(t('msg.checkpointBoth',{s1:markerStage, name1:t('stage.reply.'+markerStage), s2:actualStage, name2:t('stage.reply.'+actualStage)}));
      } else {
        addSysMsg(t('msg.checkpointDone',{s:displayStage, name:t('stage.reply.'+displayStage)}));
      }
      // 阶段4（CLAUDE.md 生成）后，在聊天区提供"重新校准"入口
      if(displayStage===4 && S.claudeMd && cm){
        setTimeout(()=>addRecalibrateButtons(), 1500);
      }
    }
  }

  // 自动弹出新生成的文件预览（对比模式不弹，用对比卡片替代）
  if(!S._pendingClaudeMd && !S._pendingSkillMd){
    if(hasNewSkills) showPreview('skill', true);
    else if(cm) showPreview('claude', true);
  }
}

function renderPatch(p,container){
  const cc={low:'conf-low',medium:'conf-med',high:'conf-high'}[p.confidence]||'conf-med';
  const card=document.createElement('div');card.className='patch-card';card.id='pc-'+p.patch_id;
  card.innerHTML=`
    <div class="patch-head"><span class="patch-field">${esc(p.field||'')}</span><span class="conf ${cc}">${p.confidence||'medium'}</span></div>
    <div class="patch-body">
      <div class="diff-grid">
        <div class="diff-box"><div class="dl cur">当前</div><div class="dc">${esc(p.current||'（空）')}</div></div>
        <div class="diff-box"><div class="dl sug">建议</div><div class="dc">${esc(p.suggestion||'')}</div></div>
      </div>
      <div class="patch-reason">原因：${esc(p.reason||'')}</div>
    </div>
    <div class="patch-acts" id="pa-${p.patch_id}">
      <button class="pb-act ok" onclick="applyP(${JSON.stringify(p).replace(/"/g,'&quot;')},true,'${p.patch_id}')">✓ 采纳</button>
      <button class="pb-act no" onclick="applyP(${JSON.stringify(p).replace(/"/g,'&quot;')},false,'${p.patch_id}')">✗ 拒绝</button>
      <button class="pb-act" onclick="editP('${p.patch_id}',${JSON.stringify(p).replace(/"/g,'&quot;')})">✎ 修改</button>
      <button class="pb-act" onclick="askAiOptions('${p.patch_id}',${JSON.stringify(p).replace(/"/g,'&quot;')})" style="color:var(--accent)">🤖 AI 给选项</button>
    </div>`;
  container.appendChild(card);
}

function applyP(p,ok,pid){
  const acts=document.getElementById('pa-'+pid);
  if(acts){acts.parentElement.className='patch-done';acts.parentElement.innerHTML=ok?'<span style="color:var(--green)">✓ 已采纳</span>':'<span style="color:var(--red)">✗ 已拒绝</span>';}
  if(ok) autoApply(p);
}
function autoApply(p){
  if(p.current&&p.suggestion){
    if(S.skillMd) S.skillMd=S.skillMd.split(p.current).join(p.suggestion);
    if(S.claudeMd) S.claudeMd=S.claudeMd.split(p.current).join(p.suggestion);
    saveFiles();
  }
}
function editP(pid,p){
  const acts=document.getElementById('pa-'+pid);
  acts.innerHTML=`<textarea id="pe-${pid}" style="flex:1;padding:5px;background:var(--bg3);border:1px solid var(--border2);border-radius:5px;font-family:var(--mono);font-size:10px;color:var(--text);min-height:55px;width:calc(100% - 105px)">${esc(p.suggestion||'')}</textarea>
    <button class="pb-act ok" onclick="confirmE('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">确认</button>
    <button class="pb-act" onclick="renderPatchActs('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">取消</button>`;
}
function confirmE(pid,p){
  const val=document.getElementById('pe-'+pid)?.value||p.suggestion;
  p.suggestion=val;applyP(p,true,pid);addSysMsg(t('msg.patchAdoptedUser',{id:pid}));
}
function renderPatchActs(pid,p){
  document.getElementById('pa-'+pid).innerHTML=`
    <button class="pb-act ok" onclick="applyP(${JSON.stringify(p).replace(/"/g,'&quot;')},true,'${pid}')">✓ 采纳</button>
    <button class="pb-act no" onclick="applyP(${JSON.stringify(p).replace(/"/g,'&quot;')},false,'${pid}')">✗ 拒绝</button>
    <button class="pb-act" onclick="editP('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">✎ 修改</button>
    <button class="pb-act" onclick="askAiOptions('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})" style="color:var(--accent)">🤖 AI 给选项</button>`;
}

async function askAiOptions(pid, p){
  const acts = document.getElementById('pa-'+pid);
  acts.innerHTML = '<span style="color:var(--accent);font-size:11px;padding:5px">🤖 AI 思考中…</span>';

  const provider = S.provider;
  const key = S.apiKeys[provider.id];
  const model = getActiveModel();
  if(!provider || !key || !model){
    acts.innerHTML = '<span style="color:var(--red);font-size:11px">⚠ 请先配置 API</span>';
    setTimeout(() => renderPatchActs(pid, p), 2000);
    return;
  }

  const prompt = `你是一个文本修改辅助。当前内容是：
---
${p.current || '（空）'}
---
建议修改为：
---
${p.suggestion || ''}
---
修改原因：${p.reason || '未说明'}

请给出3个不同方向的替代版本，每个版本一行，用数字编号。每个版本不超过2句话。从不同角度思考（简洁版、详细版、折中版）。`;

  try{
    let body = provider.buildBody([{role:'user',content:prompt}], '你是一个文本修改辅助，给出3个不同方向的替代版本。', model, key);
    let url = provider.customUrl && body._url ? body._url : provider.baseUrl;
    if(body._url) delete body._url;
    if(provider.id === 'custom'){
      const cu = document.getElementById('baseUrlInput').value.trim();
      if(cu) url = cu;
    }

    const res = await fetch(url, {method:'POST', headers: provider.headers(key), body: JSON.stringify(body)});
    if(!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();
    const reply = provider.parseReply(data);
    if(!reply) throw new Error('空回复');

    // 解析3个选项（按数字编号分割）
    const options = [];
    const lines = reply.split('\n');
    for(const line of lines){
      const m = line.match(/^\s*(\d)[\.\)、]\s*(.+)/);
      if(m && options.length < 3){
        options.push(m[2].trim());
      }
    }
    // 如果没匹配到编号格式，尝试按句号分割
    if(options.length < 2){
      const altLines = reply.split(/[。；;]\s*/).filter(l => l.trim().length > 5).slice(0, 3);
      if(altLines.length >= 2) options.push(...altLines.map(l => l.trim()));
    }

    if(options.length >= 2){
      renderAiOptions(pid, p, options);
      // 记录修补辅助使用
      trackPatchAssist(provider.id, model);
    } else {
      acts.innerHTML = `<span style="color:var(--amber);font-size:10px">⚠ AI 未返回足够的选项，请重试</span>
        <button class="pb-act" onclick="renderPatchActs('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">返回</button>`;
    }
  }catch(e){
    acts.innerHTML = `<span style="color:var(--red);font-size:10px">⚠ 请求失败：${esc(e.message.slice(0,80))}</span>
      <button class="pb-act" onclick="renderPatchActs('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">返回</button>`;
  }
}

function renderAiOptions(pid, p, options){
  const acts = document.getElementById('pa-'+pid);
  // 用临时存储避免选项文字中的特殊字符破坏 onclick
  window._aiOpts = window._aiOpts || {};
  window._aiOpts[pid] = {p, options};

  let html = '<div style="display:flex;flex-direction:column;gap:4px;width:100%">';
  html += '<div style="font-size:10px;color:var(--accent);margin-bottom:2px;font-family:var(--mono)">🤖 AI 建议的3个替代版本：</div>';
  options.forEach((opt, i) => {
    const label = ['简洁版','详细版','折中版'][i] || `选项${i+1}`;
    html += `<div style="display:flex;align-items:flex-start;gap:6px;padding:5px 7px;background:var(--bg4);border-radius:6px;font-size:11px;color:var(--text2);line-height:1.5">
      <span style="color:var(--accent);font-family:var(--mono);font-size:10px;flex-shrink:0;margin-top:1px">${label}</span>
      <span style="flex:1">${esc(opt)}</span>
      <button class="pb-act ok" style="flex-shrink:0;font-size:9px;padding:2px 7px" onclick="selectAiOption('${pid}',${i})">选这个</button>
    </div>`;
  });
  html += `<button class="pb-act" style="align-self:flex-start;margin-top:3px" onclick="renderPatchActs('${pid}',${JSON.stringify(p).replace(/"/g,'&quot;')})">← 返回手动修改</button>`;
  html += '</div>';
  acts.innerHTML = html;
}

function selectAiOption(pid, idx){
  const stored = window._aiOpts && window._aiOpts[pid];
  if(!stored) return;
  const chosenText = stored.options[idx];
  if(!chosenText) return;
  stored.p.suggestion = chosenText;
  applyP(stored.p, true, pid);
  addSysMsg(t('msg.patchAdoptedAi',{id:pid}));
  delete window._aiOpts[pid];
}

function trackPatchAssist(provider, model){
  try{
    const records = JSON.parse(ls('csg_patch_assists')||'[]');
    records.push({provider, model, timestamp: Date.now()});
    lset('csg_patch_assists', JSON.stringify(records));
  }catch(e){}
}

// 对比模式：并排展示文件旧/新版本
function renderFileCompare(type, oldContent, newContent, container){
  const label = type==='claude' ? 'CLAUDE.md' : 'SKILL.md';
  const cid = 'fcmp-'+type;
  // 截取前 40 行用于预览
  const oldPreview = oldContent ? oldContent.split('\n').slice(0,40).join('\n') : '（空文件）';
  const newPreview = newContent ? newContent.split('\n').slice(0,40).join('\n') : '（空文件）';
  const totalOld = oldContent ? oldContent.split('\n').length : 0;
  const totalNew = newContent ? newContent.split('\n').length : 0;
  const truncated = totalNew > 40;

  const card=document.createElement('div');card.className='patch-card';card.id=cid;
  card.style.marginTop='9px';
  card.innerHTML=`
    <div class="patch-head">
      <span class="patch-field">📄 ${label} 文件对比</span>
      <span class="conf conf-high">文件变更</span>
    </div>
    <div class="patch-body">
      <div style="color:var(--text3);font-size:10px;margin-bottom:6px">AI 建议更新 ${label}，请对比后确认是否采纳。${truncated ? '（预览前40行，点击采纳后应用全文）' : ''}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px">
        <div class="diff-box">
          <div class="dl cur">当前版本（${totalOld} 行）</div>
          <div class="dc" style="max-height:300px;overflow-y:auto;white-space:pre-wrap">${esc(oldPreview)}</div>
        </div>
        <div class="diff-box">
          <div class="dl sug">建议版本（${totalNew} 行）</div>
          <div class="dc" style="max-height:300px;overflow-y:auto;white-space:pre-wrap">${esc(newPreview)}</div>
        </div>
      </div>
    </div>
    <div class="patch-acts" id="fcmp-acts-${type}">
      <button class="pb-act ok" onclick="acceptFileCompare('${type}')">✓ 采纳新版</button>
      <button class="pb-act no" onclick="rejectFileCompare('${type}')">✗ 保留旧版</button>
    </div>`;
  container.appendChild(card);
  card.scrollIntoView({behavior:'smooth',block:'center'});
}

function acceptFileCompare(type){
  if(type==='claude'){
    S._prevClaudeMd=S.claudeMd;
    S.claudeMd=S._pendingClaudeMd;
    S._pendingClaudeMd=null;
    S._justGenerated='claude';
  } else {
    S._prevSkillMd=S.skillMd;
    S.skillMd=S._pendingSkillMd;
    S._pendingSkillMd=null;
    S._justGenerated='skill';
  }
  updateFileCards();
  saveFiles();
  const acts=document.getElementById('fcmp-acts-'+type);
  if(acts) acts.innerHTML='<span style="color:var(--green);padding:5px 11px;font-size:11px">✓ 已采纳新版</span>';
  addSysMsg(t('msg.compareAdopted',{type:type==='claude'?'CLAUDE.md':'SKILL.md'}));
}

function rejectFileCompare(type){
  if(type==='claude'){ S._pendingClaudeMd=null; }
  else { S._pendingSkillMd=null; }
  const acts=document.getElementById('fcmp-acts-'+type);
  if(acts) acts.innerHTML=`<span style="color:var(--red);padding:5px 11px;font-size:11px">${t('msg.compareKept',{type:type==='claude'?'CLAUDE.md':'SKILL.md'})}</span>`;
  addSysMsg(t('msg.compareKept',{type:type==='claude'?'CLAUDE.md':'SKILL.md'}));
}

// ====== PREVIEW / EXPORT ======
function showPreview(type, autoDownload=false){
  const content=type==='claude'?S.claudeMd:S.skillMd;
  const title=type==='claude'?'CLAUDE.md':'SKILL.md';
  const overlay=document.createElement('div');overlay.className='mo';
  overlay.onclick=e=>{if(e.target===overlay)overlay.remove();};
  overlay.innerHTML=`<div class="mb">
    <div class="mh"><div class="mt">${title}</div><button class="mc-btn" onclick="this.closest('.mo').remove()">×</button></div>
    <div class="mc">${esc(content||'（尚未生成）')}</div>
    <div class="mf">
      <button class="m-btn pri" onclick="copyT('${type}')">${t('fileCard.copy')}</button>
      <button class="m-btn" onclick="dlFile('${type}')">${t('fileCard.download')}</button>
      <button class="m-btn" onclick="this.closest('.mo').remove();document.getElementById('inp').focus();" style="color:var(--accent)">继续完善</button>
      <button class="m-btn" onclick="this.closest('.mo').remove()">完成 ✓</button>
    </div></div>`;
  document.body.appendChild(overlay);
  // 自动生成时触发下载，保存到本地
  if(autoDownload) dlFile(type);
}
function showLocalMdPreview(){
  const content=S.localMd;
  const overlay=document.createElement('div');overlay.className='mo';
  overlay.onclick=e=>{if(e.target===overlay)overlay.remove();};
  overlay.innerHTML=`<div class="mb">
    <div class="mh"><div class="mt">CLAUDE.local.md（个人偏好预览）</div><button class="mc-btn" onclick="this.closest('.mo').remove()">×</button></div>
    <div class="mc">${esc(content||'（尚未设置个人偏好）')}</div>
    <div class="mf">
      <button class="m-btn pri" onclick="navigator.clipboard.writeText(\`${esc(content||'').replace(/`/g,'\\`')}\`);addSysMsg(t('msg.copiedShort'));">${t('fileCard.copy')}</button>
      <button class="m-btn" onclick="generateLocalMd()">${t('fileCard.download')}</button>
      <button class="m-btn" onclick="this.closest('.mo').remove()">${t('project.close')}</button>
    </div></div>`;
  document.body.appendChild(overlay);
}
function copyT(type){navigator.clipboard.writeText(type==='claude'?S.claudeMd:S.skillMd).then(()=>addSysMsg(t('msg.copied')));}

// ====== File System Access API — 直接写入项目文件夹 ======
async function selectOutputDir(){
  try{
    const handle = await window.showDirectoryPicker({mode:'readwrite'});
    S._dirHandle = handle;
    S._dirPath = handle.name;
    document.getElementById('dirPath').textContent = '📂 ' + handle.name + ' （已就绪）';
    document.getElementById('dirPath').style.color = 'var(--green)';
    addSysMsg(t('msg.dirReady',{name:handle.name}));
  }catch(e){
    if(e.name !== 'AbortError') addSysMsg(t('msg.dirFailed',{msg:e.message}));
  }
}

function getProjectName(){
  // 从活跃项目获取名称
  try{
    const projects = JSON.parse(ls('csg_projects')||'[]');
    const activeId = ls('csg_active_project');
    const proj = projects.find(p => p.id === activeId);
    if(proj && proj.name) return proj.name.replace(/[^a-zA-Z0-9一-鿿_-]/g, '-');
  }catch(e){}
  return 'default-project';
}

async function writeFileToDir(filename, content){
  if(!S._dirHandle) return false;
  try{
    // 确保项目子文件夹存在
    const projName = getProjectName();
    let projDir;
    try{ projDir = await S._dirHandle.getDirectoryHandle(projName, {create:false}); }
    catch(e){ projDir = await S._dirHandle.getDirectoryHandle(projName, {create:true}); }
    // 写入文件
    const fileHandle = await projDir.getFileHandle(filename, {create:true});
    const writable = await fileHandle.createWritable();
    await writable.write(content);
    await writable.close();
    return true;
  }catch(e){
    console.error('writeFileToDir failed:', e);
    return false;
  }
}

async function testFileOutput(){
  if(!S._dirHandle){ alert(t('alert.selectOutputDirFirst')); return; }
  const projName = 'test';
  const testFiles = {
    'CLAUDE.md': '# Project: test\n\n## Overview\n测试项目 — 验证文件输出功能\n\n## Tech Stack\n- HTML, CSS, JavaScript\n\n## Commands\n无构建命令',
    'SKILL.md': '<skill>\n  <name>test-skill</name>\n  <description>测试用 skill</description>\n  <trigger>用户说"运行测试"</trigger>\n  <anti-trigger>用户说"跳过测试"</anti-trigger>\n</skill>',
    'test-skill.skill.md': '<skill>\n  <name>test-skill</name>\n  <description>测试用 skill — 单独文件</description>\n  <trigger>测试触发</trigger>\n</skill>'
  };
  try{
    // 用 "test" 作为项目名写入
    let projDir;
    try{ projDir = await S._dirHandle.getDirectoryHandle(projName, {create:false}); }
    catch(e){ projDir = await S._dirHandle.getDirectoryHandle(projName, {create:true}); }
    const results = [];
    for(const [fn, content] of Object.entries(testFiles)){
      const fh = await projDir.getFileHandle(fn, {create:true});
      const w = await fh.createWritable();
      await w.write(content);
      await w.close();
      results.push('✓ ' + fn);
    }
    addSysMsg(t('msg.testDone',{proj:projName, count:results.length, results:results.join('\n')}));
    document.getElementById('dirPath').textContent = '📂 ' + S._dirPath + '/test/ （测试文件已写入）';
    document.getElementById('dirPath').style.color = 'var(--green)';
  }catch(e){
    addSysMsg(t('msg.testFailed',{msg:e.message}));
  }
}

async function dlFile(type){
  let c=type==='claude'?S.claudeMd:S.skillMd,n=type==='claude'?'CLAUDE.md':'SKILL.md';
  // 注入追踪注释（仅 CLAUDE.md，避免污染 SKILL.md 的 XML）
  if(type==='claude'){
    const tracker = `\n\n<!-- generated by project-compass v2.6, session: ${S._sessionHash}, date: ${new Date().toISOString().slice(0,10)} -->`;
    if(/<!-- generated by claude-skill-generator/.test(c)){
      c = c.replace(/<!-- generated by claude-skill-generator[^>]* -->/g, tracker.trim());
    } else {
      c += tracker;
    }
  }
  // 优先直接写文件系统，否则触发下载
  if(S._dirHandle){
    const ok = await writeFileToDir(n, c);
    if(ok){ addSysMsg(t('msg.fileWritten',{path:getProjectName()+'/'+n})); }
    else{ fallbackDownload(n, c); }
  } else {
    fallbackDownload(n, c);
  }
  if(S._justGenerated && S._justGenerated === type){
    setTimeout(() => showFeedbackModal(type), 600);
    S._justGenerated = null;
  }
}

function fallbackDownload(filename, content){
  const a=document.createElement('a');
  a.href='data:text/markdown;charset=utf-8,'+encodeURIComponent(content);
  a.download=filename;a.click();
}
function exportAll(){
  let delay = 0;
  if(S.claudeMd){ dlFile('claude'); delay = 400; }
  if(S.skillMd){
    setTimeout(() => { dlFile('skill'); }, delay);
    // 也下载各独立 skill 文件
    const container = document.getElementById('skillCards');
    if(container && container._skills){
      container._skills.forEach((sk, i) => {
        setTimeout(() => { dlSkillXml('skill_'+i); }, delay + 300 + i * 200);
      });
    }
  }
  addSysMsg(t('msg.exportAllDone'));
}

// ====== 工具自优化 ======
const META_OPTIMIZE_PROMPT = `你是一个 prompt 工程专家。请审查下面的 SYSTEM_PROMPT（它用于一个 Claude Code 项目规范生成器工具），并提出具体改进建议。

审查维度：
1. **时效性**：是否有过时的模型名称、API 端点、已淘汰的功能？
2. **完整性**：是否缺少 Claude Code 最新特性的支持（如 memory 系统、worktree、plan mode、MCP servers 等）？
3. **清晰度**：指令是否有歧义？AI 执行时可能产生什么误解？
4. **实用性**：每个阶段是否真正收集了生成高质量 CLAUDE.md 所需的信息？
5. **触发条件设计**：SKILL.md 的触发条件设计指导是否足够具体？
6. **冗余**：是否有重复或自相矛盾的指令？

要求：
- 每条建议单独写一行 JSON，格式：{"patch_id":"opt_N","target":"system_prompt","field":"[具体位置，如 Stage 1 > 第二步]","current":"[当前文本片段，需精确匹配以便程序替换]","suggestion":"[改进后的文本]","reason":"[为什么改，从 prompt 工程角度说明]","confidence":"high|medium|low"}
- 至少输出 2 条建议，最多 6 条
- 只输出真正有改进价值的建议，不要为了凑数而提
- 如果 prompt 已经很好，可以说"未发现需要改进的地方"
- 当前文本片段必须能在 SYSTEM_PROMPT 中精确匹配到，否则无法自动替换`;

async function optimizePrompt(){
  if(!S.provider){alert(t('alert.selectProviderForOptimize'));return;}
  const key=S.apiKeys[S.provider.id];
  if(!key){alert(t('alert.configureApiKey'));return;}
  const model=getActiveModel();
  if(!model){alert(t('alert.selectModel'));return;}
  if(S.loading){return;}

  addSysMsg(t('msg.optimizeStart'));
  S.loading=true;
  document.getElementById('outOptimize').disabled=true;
  showTyping();

  try{
    const p=S.provider;
    const sys='你是一个 prompt 工程专家。用中文回复。';
    const msgs=[{role:'user',content:`${META_OPTIMIZE_PROMPT}\n\n=== 待审查的 SYSTEM_PROMPT ===\n${S.systemPrompt}`}];
    let body=p.buildBody(msgs,sys,model,key);
    let url=p.customUrl&&body._url?body._url:p.baseUrl;
    if(body._url) delete body._url;
    if(p.id==='custom'){
      const cu=document.getElementById('baseUrlInput').value.trim();
      if(cu) url=cu;
    }

    const res=await fetch(url,{method:'POST',headers:p.headers(key),body:JSON.stringify(body)});
    if(!res.ok){const err=await res.text();throw new Error(httpErrorMsg(res.status, err));}
    const data=await res.json();
    const reply=p.parseReply(data);
    if(!reply) throw new Error('AI 返回了空回复');

    removeTyping();
    // 解析修补建议
    const patches=[];
    const pr=/^\{[^{}\n]*"patch_id"[^{}\n]*\}$/gm;let pm;
    while((pm=pr.exec(reply))!==null){
      try{const parsed=JSON.parse(pm[0]);if(parsed.target==='system_prompt')patches.push(parsed);}catch(e){}
    }

    if(patches.length===0){
      addMsg('ai',`🔧 工具自检完成。AI 的反馈：\n\n${reply.slice(0,500)}${reply.length>500?'…':''}\n\n未检测到需要自动应用的修补建议。`);
    } else {
      addMsg('ai',`🔧 工具自检完成，发现 <b>${patches.length} 条</b>可优化的地方。请逐条审核：`);
      const lastBubble=document.querySelector('#chat .bubble:last-of-type');
      patches.forEach(p=>renderOptimizePatch(p, lastBubble||document.getElementById('chat')));
    }
  }catch(e){
    removeTyping();
    addMsg('ai',`⚠️ 工具自检失败：${e.message}`);
  }
  S.loading=false;
  document.getElementById('outOptimize').disabled=false;
}

function renderOptimizePatch(p, container){
  const cc={high:'conf-high',medium:'conf-med',low:'conf-low'}[p.confidence]||'conf-med';
  const card=document.createElement('div');
  card.className='patch-card';
  card.id='opt-'+p.patch_id;
  card.style.borderColor='rgba(124,106,247,0.5)';
  card.innerHTML=`
    <div class="patch-head">
      <span class="patch-field">🔧 ${esc(p.field||'SYSTEM_PROMPT')}</span>
      <span class="conf ${cc}">${p.confidence||'medium'}</span>
    </div>
    <div class="patch-body">
      <div class="diff-grid">
        <div class="diff-box"><div class="dl cur">当前</div><div class="dc" style="max-height:120px;overflow-y:auto">${esc((p.current||'').slice(0,300))}${(p.current||'').length>300?'…':''}</div></div>
        <div class="diff-box"><div class="dl sug">建议</div><div class="dc" style="max-height:120px;overflow-y:auto">${esc((p.suggestion||'').slice(0,300))}${(p.suggestion||'').length>300?'…':''}</div></div>
      </div>
      <div class="patch-reason">原因：${esc(p.reason||'')}</div>
    </div>
    <div class="patch-acts" id="opt-acts-${p.patch_id}">
      <button class="pb-act ok" onclick="acceptOptimize('${p.patch_id}')">✓ 应用</button>
      <button class="pb-act no" onclick="rejectOptimize('${p.patch_id}')">✗ 拒绝</button>
      <button class="pb-act" onclick="editOptimize('${p.patch_id}')">✎ 手动编辑</button>
    </div>`;
  container.appendChild(card);
  card.scrollIntoView({behavior:'smooth',block:'center'});

  // 暂存 patch 数据
  window._optPatches = window._optPatches || {};
  window._optPatches[p.patch_id] = p;
}

function acceptOptimize(pid){
  const p = window._optPatches && window._optPatches[pid];
  if(!p) return;
  // 精确替换
  if(p.current && S.systemPrompt.includes(p.current)){
    S.systemPrompt = S.systemPrompt.split(p.current).join(p.suggestion);
  } else if(p.suggestion){
    // 如果精确匹配失败，追加到末尾作为补充说明
    S.systemPrompt += '\n\n<!-- 用户采纳的优化 -->\n' + p.suggestion;
  }
  try{ localStorage.setItem('csg_system_prompt', S.systemPrompt); }catch(e){}
  const acts=document.getElementById('opt-acts-'+pid);
  if(acts) acts.innerHTML='<span style="color:var(--green);padding:5px 11px;font-size:11px">✓ 已应用 — 下次对话生效</span>';
  addSysMsg(t('msg.optimizeApplied',{id:pid}));
  delete window._optPatches[pid];
}

function rejectOptimize(pid){
  const acts=document.getElementById('opt-acts-'+pid);
  if(acts) acts.innerHTML='<span style="color:var(--red);padding:5px 11px;font-size:11px">✗ 已拒绝</span>';
  delete window._optPatches[pid];
}

function editOptimize(pid){
  const p = window._optPatches && window._optPatches[pid];
  if(!p) return;
  const acts=document.getElementById('opt-acts-'+pid);
  acts.innerHTML=`<textarea id="opt-edit-${pid}" style="flex:1;padding:5px;background:var(--bg3);border:1px solid var(--border2);border-radius:5px;font-family:var(--mono);font-size:10px;color:var(--text);min-height:55px;width:100%;margin-bottom:5px">${esc(p.suggestion||'')}</textarea>
    <div style="display:flex;gap:5px"><button class="pb-act ok" onclick="confirmOptimizeEdit('${pid}')">确认</button>
    <button class="pb-act" onclick="cancelOptimizeEdit('${pid}')">取消</button></div>`;
}

function confirmOptimizeEdit(pid){
  const val=document.getElementById('opt-edit-'+pid)?.value;
  if(val && window._optPatches[pid]){
    window._optPatches[pid].suggestion = val;
  }
  acceptOptimize(pid);
}

function cancelOptimizeEdit(pid){
  const p = window._optPatches && window._optPatches[pid];
  if(!p) return;
  const acts=document.getElementById('opt-acts-'+pid);
  acts.innerHTML=`
    <button class="pb-act ok" onclick="acceptOptimize('${pid}')">✓ 应用</button>
    <button class="pb-act no" onclick="rejectOptimize('${pid}')">✗ 拒绝</button>
    <button class="pb-act" onclick="editOptimize('${pid}')">✎ 手动编辑</button>`;
}

function resetAll(){
  autoSaveProject(); // 重置前先保存当前状态
  S.history=[];S.claudeMd='';S.skillMd='';S.loading=false;S.stage=0;
  S._prevClaudeMd='';S._prevSkillMd='';S._pendingClaudeMd=null;S._pendingSkillMd=null;
  S._justGenerated=null;
  document.getElementById('chat').innerHTML='';
  ['outExport'].forEach(id=>document.getElementById(id).disabled=true);
  document.getElementById('sendBtn').disabled=false;
  setStage(0);
  lremove('csg_claude_md');lremove('csg_skill_md');
  updateFileCards();
  addMsg('ai','已重置。请描述新项目。');
}

function clearAllData(){
  if(!confirm('确定要清空所有数据吗？\n\n将清除：API Key、模型选择、生成的文件、项目列表、所有 localStorage 数据。\n\n此操作不可撤销。')) return;
  localStorage.clear();
  location.reload();
}

// ====== AI 知识面板 ======
function getKnowledgeItems(){
  const Z=[
    {tag:'tip',tagLabel:'提示词技巧',text:'在 SYSTEM_PROMPT 中明确写出"禁止做的事"，比只写"应该做的事"更能防止 AI 越界。负面指令放在末尾效果更好。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'长 prompt 中，把最重要的指令放在开头和末尾（首因效应+近因效应）。中间的指令容易被 AI "遗忘"。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'给 AI 提供"好"和"坏"的输出示例，比纯文字描述格式要求有效 3 倍以上。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'触发条件设计要具体到关键词+上下文，避免"涉及文件操作时使用"这类泛泛表述——它会被所有任务触发。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'对于复杂任务，用 [STAGE:N] 标记强制 AI 按步骤执行，并在每步末尾要求确认。这能显著减少跳步和遗漏。'},
    {tag:'news',tagLabel:'模型动态',text:'Claude Code 现在支持 .claude/rules/ 路径作用域规则，可按文件类型或目录加载不同指令，避免 CLAUDE.md 过长。'},
    {tag:'news',tagLabel:'模型动态',text:'Claude Code 支持 auto memory（自动记忆），会自己保存调试经验和偏好到 ~/.claude/projects/ 目录。'},
    {tag:'news',tagLabel:'模型动态',text:'CLAUDE.md 支持 @README.md 等文件导入语法，可在已有 README 的项目中避免重复内容。'},
    {tag:'news',tagLabel:'模型动态',text:'Claude 4.7 Opus 支持 Fast Mode，输出速度更快。如果你的工具需要快速响应，优先选择 Opus 4.7。'},
    {tag:'news',tagLabel:'模型动态',text:'CLAUDE.local.md 是 gitignored 的个人偏好文件，适合存放 sandbox URL、本地测试数据等不共享的设置。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'CLAUDE.md 超过 200 行会消耗更多上下文且降低遵循度。建议用 .claude/rules/ 按路径作用域拆分。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'双模型架构（Claude Code壳+DeepSeek脑）下，CLAUDE.md 用中文写、指令强硬；SKILL.md 由 Claude Code 解析，用英文写触发条件。'},
    {tag:'tip',tagLabel:'提示词技巧',text:'CLAUDE.md 中的 User Profile 章节是最重要的上下文——它决定了 AI 的解释深度、回复风格和自主程度。'},
    {tag:'warn',tagLabel:'注意',text:'不同 AI 模型对 SYSTEM_PROMPT 的理解能力差异很大。Gemini 对 systemInstruction 的遵守度低于在 messages 中直接给指令。'},
    {tag:'warn',tagLabel:'注意',text:'API Key 存储在 localStorage 中是明文，不要在不信任的设备上使用。生产环境应使用后端代理。'},
    {tag:'warn',tagLabel:'注意',text:'Auto memory 是机器本地的，不会跨机器共享。CLAUDE.md 才是团队共享的规范文件。'},
  ];
  const E=[
    {tag:'tip',tagLabel:'Prompt Tips',text:'Explicitly write "do NOT do X" — negative constraints at the END of prompts are more effective than only stating positive rules.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'Place the most important instructions at the beginning and end of long prompts (primacy + recency effects). Middle instructions are easily "forgotten" by AI.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'Providing both "good" and "bad" output examples is 3x more effective than text descriptions alone for format requirements.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'Design triggers to be keyword+context specific. Avoid vague phrases like "use when working with files" — they trigger on every task.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'For complex tasks, use [STAGE:N] markers to force step-by-step execution with confirmation at each step. This significantly reduces skipped steps.'},
    {tag:'news',tagLabel:'Model Updates',text:'Claude Code now supports .claude/rules/ path-scoped rules, loading different instructions by file type or directory to keep CLAUDE.md concise.'},
    {tag:'news',tagLabel:'Model Updates',text:'Claude Code supports auto memory — it automatically saves debugging insights and preferences to ~/.claude/projects/.'},
    {tag:'news',tagLabel:'Model Updates',text:'CLAUDE.md supports @README.md file import syntax, avoiding duplicate content in projects with existing documentation.'},
    {tag:'news',tagLabel:'Model Updates',text:'Claude 4.7 Opus supports Fast Mode for faster output. Prefer Opus 4.7 if your tool needs quick response times.'},
    {tag:'news',tagLabel:'Model Updates',text:'CLAUDE.local.md is a gitignored personal preferences file — ideal for sandbox URLs, local test data, and other non-shared settings.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'CLAUDE.md exceeding 200 lines costs more context and reduces compliance. Split into .claude/rules/ by path scope.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'In dual-model setups (Claude Code shell + DeepSeek brain), write CLAUDE.md instructions forcefully; SKILL.md is parsed by Claude Code so use English triggers.'},
    {tag:'tip',tagLabel:'Prompt Tips',text:'The User Profile section in CLAUDE.md is the most important context — it determines AI explanation depth, response style, and autonomy level.'},
    {tag:'warn',tagLabel:'Warning',text:'AI models vary widely in system prompt comprehension. Gemini follows systemInstruction less reliably than instructions in messages.'},
    {tag:'warn',tagLabel:'Warning',text:'API Keys in localStorage are plaintext. Do not use on untrusted devices. Production environments should use a backend proxy.'},
    {tag:'warn',tagLabel:'Warning',text:'Auto memory is machine-local and does not sync across devices. CLAUDE.md is your team\'s shared specification file.'},
  ];
  return S.locale==='en'?E:Z;
}

function refreshKnowledge(){
  const panel = document.getElementById('knowledgePanel');
  if(!panel) return;
  // 随机选 3 条，保证不同类型各一条
  const items = getKnowledgeItems();
  const tips = items.filter(k=>k.tag==='tip');
  const news = items.filter(k=>k.tag==='news');
  const warns = items.filter(k=>k.tag==='warn');
  const selected = [
    tips[Math.floor(Math.random()*tips.length)],
    news[Math.floor(Math.random()*news.length)],
    warns[Math.floor(Math.random()*warns.length)]
  ];
  // 打乱顺序
  for(let i=selected.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[selected[i],selected[j]]=[selected[j],selected[i]];}

  panel.innerHTML = selected.map(k => `
    <div class="knowledge-item">
      <span class="ki-tag ${k.tag}">${k.tagLabel}</span>
      ${k.text}
    </div>`).join('') + `<div class="knowledge-refresh" onclick="refreshKnowledge()">🔄 ${t('knowledge.shuffle')}</div>`;
}

// ====== GITHUB SYNC ======
function toggleGitHub(){
  const panel = document.getElementById('githubPanel');
  const arrow = document.getElementById('githubToggle');
  const collapsed = panel.style.display === 'none';
  panel.style.display = collapsed ? '' : 'none';
  arrow.classList.toggle('folded', !collapsed);
  lset('csg_github_collapsed', collapsed ? '0' : '1');
}

function onGitHubChange(){
  S.githubToken = document.getElementById('githubToken').value.trim();
  S.githubRepo = document.getElementById('githubRepo').value.trim();
  S.githubBranch = document.getElementById('githubBranch').value.trim() || 'main';
  S.githubPath = document.getElementById('githubPath').value.trim();
  lset('csg_github_token', S.githubToken);
  lset('csg_github_repo', S.githubRepo);
  lset('csg_github_branch', S.githubBranch);
  lset('csg_github_path', S.githubPath);
  updateGitHubStatus();
}

function updateGitHubStatus(){
  const btn = document.getElementById('outGitHubSync');
  const status = document.getElementById('githubStatus');
  const hasFiles = S.claudeMd || S.skillMd;
  const hasConfig = S.githubToken && S.githubRepo;
  btn.disabled = !hasFiles || !hasConfig || S.loading;
  if(!hasConfig){
    status.textContent = t('github.noConfig');
  } else if(!hasFiles){
    status.textContent = t('github.noFiles');
  } else {
    status.textContent = t('github.ready');
  }
}

async function syncToGitHub(){
  if(!S.githubToken || !S.githubRepo){ addSysMsg(t('github.noConfig')); return; }
  if(!S.claudeMd && !S.skillMd){ addSysMsg(t('github.noFiles')); return; }
  const btn = document.getElementById('outGitHubSync');
  const status = document.getElementById('githubStatus');
  btn.disabled = true;
  btn.textContent = t('github.syncing');
  const branch = S.githubBranch || 'main';
  const basePath = S.githubPath ? S.githubPath.replace(/\/+$/,'') + '/' : '';
  const files = [];
  if(S.claudeMd) files.push({path: basePath + 'CLAUDE.md', content: S.claudeMd});
  if(S.skillMd) files.push({path: basePath + 'SKILL.md', content: S.skillMd});
  // 从 SKILL.md 中提取独立 skill 文件
  if(S.skillMd){
    const re = /<skill>[\s\S]*?<\/skill>/gi;
    let m;
    while((m = re.exec(S.skillMd)) !== null){
      const xml = m[0];
      const name = (xml.match(/<name>([^<]*)<\/name>/i)||[])[1];
      if(name){
        files.push({path: basePath + '.claude/skills/' + name + '.skill.md', content: xml});
      }
    }
  }

  try{
    let successCount = 0;
    for(const file of files){
      await upsertGitHubFile(file.path, file.content, branch);
      successCount++;
    }
    status.textContent = t('github.syncDone', {files: successCount + '/' + files.length});
    addSysMsg(t('github.syncDone', {files: successCount + '/' + files.length}));
  } catch(e){
    status.textContent = t('github.syncFailed', {msg: e.message});
    addSysMsg(t('github.syncFailed', {msg: e.message}));
  }
  btn.disabled = false;
  btn.textContent = t('github.sync');
}

async function upsertGitHubFile(path, content, branch){
  const [owner, repo] = S.githubRepo.split('/');
  if(!owner || !repo) throw new Error(t('github.syncFailed', {msg: 'bad repo format'}));
  const url = `https://api.github.com/repos/${encodeURIComponent(owner)}/${encodeURIComponent(repo)}/contents/${path}`;
  // 先查文件是否存在，获取 sha
  let sha = '';
  try{
    const checkRes = await fetch(url + '?ref=' + encodeURIComponent(branch), {
      headers: {'Authorization': 'Bearer ' + S.githubToken, 'Accept': 'application/vnd.github+json'}
    });
    if(checkRes.ok){
      const data = await checkRes.json();
      sha = data.sha;
    }
  } catch(e){}
  // 用 TextEncoder 编码 UTF-8，分块转 base64 避免栈溢出
  const encoder = new TextEncoder();
  const bytes = encoder.encode(content);
  let base64 = '';
  const chunk = 0x8000;
  for(let i = 0; i < bytes.length; i += chunk){
    base64 += String.fromCharCode.apply(null, bytes.subarray(i, i + chunk));
  }
  base64 = btoa(base64);
  const body = {
    message: sha ? 'Update ' + path : 'Add ' + path,
    content: base64,
    branch: branch
  };
  if(sha) body.sha = sha;
  const res = await fetch(url, {
    method: 'PUT',
    headers: {'Authorization': 'Bearer ' + S.githubToken, 'Accept': 'application/vnd.github+json', 'Content-Type': 'application/json'},
    body: JSON.stringify(body)
  });
  if(!res.ok){
    const err = await res.json().catch(()=>({}));
    throw new Error(err.message || 'HTTP ' + res.status);
  }
}

function initGitHub(){
  document.getElementById('githubToken').value = S.githubToken;
  document.getElementById('githubRepo').value = S.githubRepo;
  document.getElementById('githubBranch').value = S.githubBranch;
  document.getElementById('githubPath').value = S.githubPath;
  const collapsed = ls('csg_github_collapsed');
  if(collapsed === '1'){
    document.getElementById('githubPanel').style.display = 'none';
    document.getElementById('githubToggle').classList.add('folded');
  }
  updateGitHubStatus();
}

init();
</script>
</body>
</html>
