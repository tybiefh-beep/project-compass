    ],
    defaultModel:'deepseek-chat',
    headers: k=>({'Content-Type':'application/json','Authorization':'Bearer '+k}),
    buildBody:(msgs,sys,model)=>{
      // 标准模型用 system 消息；自定义模型（代理）合并到 user 消息，避免代理拒绝 system 角色
      const stdModels = ['deepseek-chat','deepseek-reasoner','deepseek-coder','deepseek-v2.5','deepseek-v4-pro'];
      if(!stdModels.includes(model) && sys){
        const merged = msgs.map(m=>({...m}));
        const idx = merged.findIndex(m=>m.role==='user');
        if(idx>=0) merged[idx] = {...merged[idx], content: sys + '\n\n' + merged[idx].content};
        else merged.unshift({role:'user', content: sys});
        return {model, max_tokens:4096, messages: merged};
      }
      return {model, max_tokens:4096, messages:[{role:'system',content:sys},...msgs]};
    },
    parseReply: d=>d.choices?.[0]?.message?.content||'',
    verifyBody: model=>({model,max_tokens:512,messages:[{role:'user',content:'Reply with OK'}]}),
    verifyCheck: d=>!!(d.choices?.[0]?.message?.content),
    promptPatch: '\n\n## 重要输出格式要求（DeepSeek 专用）\n- 严格按照阶段定义执行，一次只推进一个阶段\n- 输出 [STAGE:N] 标记后直接进入内容，不要额外的前言说明\n- xml 代码块必须用 ```xml 包裹，代码块外不要有任何说明文字\n- 不要输出"以下是生成的 SKILL.md："这类引导语句',
    preprocessReply: function(reply){ if(!reply) return reply; let r=reply.replace(/^[\s\S]*?(?=\[STAGE:\d\]|```(?:markdown|xml|bash)?)/, ''); if(!r) r=reply; if(!/\[STAGE:\d\]/.test(r)&&!/```/.test(r)) return reply; return r; }
  },
